---
interface Props {
  faqs: { question: string; answer: string }[];
}
const { faqs } = Astro.props;
---

<div class="divide-y divide-charcoal/5">
  {faqs.map((faq) => (
    <details class="group py-8 cursor-pointer">
      <summary class="flex items-center justify-between">
        <h4 class="font-editorial text-xl lg:text-2xl font-normal text-charcoal pr-8">{faq.question}</h4>
        <span class="text-terracotta/40 group-open:rotate-45 transition-transform duration-300 flex-shrink-0 text-2xl font-light">+</span>
      </summary>
      <div class="mt-6 text-charcoal/60 leading-relaxed text-base max-w-2xl">
        {faq.answer}
      </div>
    </details>
  ))}
</div>
