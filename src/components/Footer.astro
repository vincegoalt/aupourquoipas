---
import { site } from '../data/site';
---

<footer class="bg-charcoal text-warm-white py-24 lg:py-32">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
    <div class="flex flex-col lg:flex-row justify-between gap-16 mb-20">
      <!-- Logo -->
      <div>
        <a class="font-editorial text-xl tracking-[0.15em] text-warm-white" href="/">AU POUR QUOI PAS</a>
      </div>

      <!-- Nav -->
      <nav class="flex flex-wrap gap-x-12 gap-y-3">
        <a class="text-warm-white/40 hover:text-terracotta transition-colors duration-300 font-sans text-[11px] tracking-[0.2em] uppercase" href="/ateliers-respiration-coherence-cardiaque/">Ateliers</a>
        <a class="text-warm-white/40 hover:text-terracotta transition-colors duration-300 font-sans text-[11px] tracking-[0.2em] uppercase" href="/tarifs/">Tarifs</a>
        <a class="text-warm-white/40 hover:text-terracotta transition-colors duration-300 font-sans text-[11px] tracking-[0.2em] uppercase" href="/a-propos/">A Propos</a>
        <a class="text-warm-white/40 hover:text-terracotta transition-colors duration-300 font-sans text-[11px] tracking-[0.2em] uppercase" href="/contact/">Contact</a>
      </nav>
    </div>

    <!-- Address & Email -->
    <div class="flex flex-col md:flex-row justify-between gap-8 mb-16 pb-16 border-b border-warm-white/10">
      <div class="text-warm-white/30 text-sm font-light">
        <p>{site.address.street}</p>
        <p>{site.address.postalCode} {site.address.city}</p>
      </div>
      <div>
        <a href={`mailto:${site.email}`} class="text-terracotta hover:text-terracotta/70 transition-colors text-sm">{site.email}</a>
      </div>
    </div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row justify-between gap-4 text-warm-white/20 text-[11px] tracking-[0.15em] uppercase">
      <p>&copy; 2026 Au Pour Quoi Pas</p>
      <a href="/mentions-legales/" class="hover:text-terracotta transition-colors">Mentions Legales</a>
    </div>
  </div>
</footer>
