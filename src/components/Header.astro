---
const navLinks = [
  { label: "Ateliers", href: "/ateliers-respiration-coherence-cardiaque/" },
  { label: "Tarifs", href: "/tarifs/" },
  { label: "Contact", href: "/contact/" },
  { label: "A Propos", href: "/a-propos/" },
];
---

<nav id="main-nav" class="fixed top-0 w-full z-[100] transition-all duration-300">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-24 py-6 flex justify-between items-center">
    <a class="font-editorial text-xl font-normal tracking-[0.15em] text-charcoal" href="/">
      AU POUR QUOI PAS
    </a>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          class="font-sans text-[11px] tracking-[0.2em] uppercase text-charcoal/60 hover:text-terracotta transition-colors duration-300"
          href={link.href}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact/"
        class="font-sans text-[11px] tracking-[0.2em] uppercase text-terracotta hover:text-terracotta/70 transition-colors duration-300"
      >
        Reserver
      </a>
    </div>

    <!-- Mobile Menu Toggle -->
    <button id="mobile-toggle" class="lg:hidden text-charcoal" aria-label="Menu">
      <svg id="menu-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
      <svg id="close-icon" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="hidden lg:hidden bg-warm-white/95 backdrop-blur-sm px-6 pb-8 pt-4">
    {navLinks.map((link) => (
      <a href={link.href} class="block py-3 font-editorial text-lg text-charcoal hover:text-terracotta transition-colors">
        {link.label}
      </a>
    ))}
    <a href="/contact/" class="block py-3 text-terracotta font-sans text-[11px] tracking-[0.2em] uppercase mt-4">
      Reserver
    </a>
  </div>
</nav>

<script>
  const initNav = () => {
    const nav = document.getElementById('main-nav');
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    // Scroll background
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav?.classList.add('bg-[#FAFAF7]/90', 'backdrop-blur-sm');
      } else {
        nav?.classList.remove('bg-[#FAFAF7]/90', 'backdrop-blur-sm');
      }
    }, { passive: true });

    // Mobile toggle
    toggle?.addEventListener('click', () => {
      const isHidden = menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden');
      menuIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });
  };

  document.addEventListener('astro:page-load', initNav);
  document.addEventListener('astro:after-swap', initNav);
</script>
