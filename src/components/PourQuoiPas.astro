---
// Signature 3-column brand block — Quiet Luxury Editorial
---

<section class="py-32 lg:py-48 bg-warm-white">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
    <div class="flex flex-col md:flex-row border-t border-charcoal/5">
      <!-- POUR -->
      <div class="flex-1 py-16 lg:py-24 px-8 lg:px-12 md:border-r border-charcoal/5 text-center reveal">
        <h3 class="font-editorial text-7xl lg:text-8xl font-light text-charcoal mb-10">Pour</h3>
        <div class="space-y-3 text-[10px] tracking-[0.2em] uppercase text-sage">
          <p>Harmoniser</p>
          <p>Equilibrer</p>
          <p>Calmer</p>
        </div>
      </div>

      <!-- QUOI -->
      <div class="flex-1 py-16 lg:py-24 px-8 lg:px-12 md:border-r border-charcoal/5 text-center reveal">
        <h3 class="font-editorial text-7xl lg:text-8xl font-light text-charcoal mb-10">Quoi</h3>
        <div class="space-y-3 text-[10px] tracking-[0.2em] uppercase text-sage">
          <p>Le Souffle</p>
          <p>L'Instant</p>
          <p>La Presence</p>
        </div>
      </div>

      <!-- PAS -->
      <div class="flex-1 py-16 lg:py-24 px-8 lg:px-12 text-center reveal">
        <h3 class="font-editorial text-7xl lg:text-8xl font-light text-charcoal mb-10">Pas</h3>
        <div class="space-y-3 text-[10px] tracking-[0.2em] uppercase text-sage">
          <p>Oser</p>
          <p>Ancrer</p>
          <p>Rayonner</p>
        </div>
      </div>
    </div>
  </div>
</section>
