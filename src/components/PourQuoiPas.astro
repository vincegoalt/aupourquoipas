---
// Signature 3-column brand block — Premium Stitch v2
---

<section class="py-40 bg-tertiary text-surface overflow-hidden relative">
  <div class="container mx-auto px-8 relative z-10">
    <div class="flex flex-col md:flex-row gap-1 border-t border-b border-white/10">
      <!-- POUR -->
      <div class="flex-1 py-32 px-12 border-r border-white/10 group hover:bg-white/5 transition-colors text-center">
        <h3 class="serif-display text-8xl md:text-9xl italic font-extralight text-primary mb-12 opacity-80 group-hover:opacity-100 transition-opacity">Pour</h3>
        <div class="space-y-4 text-sm tracking-[0.4em] uppercase font-bold text-white/40">
          <p>Harmoniser</p>
          <p>Équilibrer</p>
          <p>Calmer</p>
        </div>
      </div>

      <!-- QUOI -->
      <div class="flex-1 py-32 px-12 border-r border-white/10 group hover:bg-white/5 transition-colors text-center">
        <h3 class="serif-display text-8xl md:text-9xl italic font-extralight text-primary mb-12 opacity-80 group-hover:opacity-100 transition-opacity">Quoi</h3>
        <div class="space-y-4 text-sm tracking-[0.4em] uppercase font-bold text-white/40">
          <p>Le Souffle</p>
          <p>L'Instant</p>
          <p>La Présence</p>
        </div>
      </div>

      <!-- PAS -->
      <div class="flex-1 py-32 px-12 group hover:bg-white/5 transition-colors text-center">
        <h3 class="serif-display text-8xl md:text-9xl italic font-extralight text-primary mb-12 opacity-80 group-hover:opacity-100 transition-opacity">Pas</h3>
        <div class="space-y-4 text-sm tracking-[0.4em] uppercase font-bold text-white/40">
          <p>Oser</p>
          <p>Ancrer</p>
          <p>Rayonner</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Background text -->
  <div class="absolute inset-0 opacity-[0.04] flex items-center justify-center pointer-events-none">
    <span class="serif-display text-[40vw] font-black tracking-tighter -rotate-12 translate-y-40">SOUFFLE</span>
  </div>
</section>
