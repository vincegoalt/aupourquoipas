---
// Signature 3-column brand block
---

<section class="py-32 bg-surface-container-high overflow-hidden">
  <div class="container mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-1 px-1">
      <!-- POUR -->
      <div class="bg-surface p-16 flex flex-col items-center text-center rounded-l-[4rem] md:rounded-l-[4rem] md:rounded-r-none rounded-t-[4rem] md:rounded-t-none md:rounded-tl-[4rem]">
        <h3 class="serif-display text-5xl italic text-primary mb-8">POUR</h3>
        <ul class="space-y-4 font-[Newsreader] text-2xl text-on-surface">
          <li>harmoniser</li>
          <li>équilibrer</li>
          <li>calmer</li>
        </ul>
      </div>

      <!-- QUOI -->
      <div class="bg-surface p-16 flex flex-col items-center text-center">
        <h3 class="serif-display text-5xl italic text-primary mb-8">QUOI</h3>
        <ul class="space-y-4 font-[Newsreader] text-2xl text-on-surface">
          <li>le souffle</li>
          <li>l'évaluation</li>
          <li>la pratique</li>
        </ul>
      </div>

      <!-- PAS -->
      <div class="bg-surface p-16 flex flex-col items-center text-center rounded-r-[4rem] md:rounded-r-[4rem] md:rounded-l-none rounded-b-[4rem] md:rounded-b-none md:rounded-br-[4rem]">
        <h3 class="serif-display text-5xl italic text-primary mb-8">PAS</h3>
        <ul class="space-y-4 font-[Newsreader] text-2xl text-on-surface">
          <li>oser</li>
          <li>routine</li>
          <li>mouvement</li>
        </ul>
      </div>
    </div>
  </div>
</section>
