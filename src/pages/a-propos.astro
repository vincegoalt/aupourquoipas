---
import BaseLayout from '../components/BaseLayout.astro';
import PourQuoiPas from '../components/PourQuoiPas.astro';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "name": site.owner.name,
      "jobTitle": site.owner.title,
      "worksFor": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "description": site.owner.shortBio
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "À Propos" }
      ]
    }
  ]
};
---

<BaseLayout
  title="À Propos de Stéphanie | Au Pour Quoi Pas"
  description="Podologue posturologue et énergéticienne depuis plus de 20 ans, Stéphanie vous accompagne vers le bien-être à Mortagne-au-Perche."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">À Propos</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <span class="text-secondary font-[Inter] text-sm tracking-[0.3em] uppercase block">Fondatrice</span>
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">Stéphanie</h1>
      <p class="serif-display text-2xl italic text-on-surface-variant">{site.owner.title}</p>
      <p class="text-xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        {site.owner.shortBio}
      </p>
    </div>
    <div class="relative">
      <div class="w-full aspect-[4/5] bg-surface-container-high rounded-[5rem] shadow-lg overflow-hidden">
        <img
          alt="Stéphanie, fondatrice d'Au Pour Quoi Pas, dans son atelier à Mortagne-au-Perche"
          src="/images/stephanie/portrait.webp"
          class="w-full h-full object-cover"
          width="600"
          height="750"
          loading="eager"
        />
      </div>
      <div class="absolute -bottom-10 -right-10 bg-secondary w-64 h-64 rounded-full -z-10 opacity-20 blur-3xl"></div>
    </div>
  </section>

  <!-- Full Story -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="max-w-3xl mx-auto">
      <h2 class="serif-display text-5xl mb-16 text-center">Mon Parcours</h2>

      <div class="space-y-16">
        <!-- Chapter 1: Origins -->
        <div class="space-y-6">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-2xl text-primary">nature_people</span>
            </div>
            <h3 class="serif-display text-3xl">Enracinée dans le Perche</h3>
          </div>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            Originaire du Perche, j'ai toujours vécu proche de la nature. Toute mon enfance jusqu'à l'âge de 22 ans, j'ai grandi dans l'univers du sport — la course à pied de manière intense — avec une première découverte du corps et ses blessures.
          </p>
        </div>

        <!-- Chapter 2: Studies -->
        <div class="space-y-6">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-2xl text-primary">school</span>
            </div>
            <h3 class="serif-display text-3xl">Du Soin à la Posturologie</h3>
          </div>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            Mes études m'ont amenée vers le soin — d'abord Pédicure-Podologue, puis Posturologue, où j'ai découvert une approche plus holistique pour traiter les douleurs chroniques.
          </p>
        </div>

        <!-- Chapter 3: The Question -->
        <div class="space-y-6">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-2xl text-primary">psychology</span>
            </div>
            <h3 class="serif-display text-3xl">La Réflexion Fondatrice</h3>
          </div>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            De ces douleurs chroniques s'est posée la réflexion de la posture et des émotions : qu'est-ce que le corps veut nous dire à travers ces douleurs et maladies ? Cette question a transformé toute ma pratique.
          </p>
          <blockquote class="border-l-4 border-primary/30 pl-8 py-4 my-10">
            <p class="serif-display text-2xl italic text-primary">
              « Qu'est-ce que le corps veut nous dire à travers ces douleurs et maladies ? »
            </p>
          </blockquote>
        </div>

        <!-- Chapter 4: Energy Work -->
        <div class="space-y-6">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-2xl text-primary">energy_savings_leaf</span>
            </div>
            <h3 class="serif-display text-3xl">Vers l'Énergétique</h3>
          </div>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            Aujourd'hui, en plus de mon métier de Podologue Posturologue, je propose des soins énergétiques qui travaillent sur la mémoire cellulaire du corps pour l'aider à libérer des blocages énergétiques et émotionnels.
          </p>
        </div>

        <!-- Chapter 5: Au Pour Quoi Pas -->
        <div class="space-y-6">
          <div class="flex items-center gap-6 mb-8">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-2xl text-primary">favorite</span>
            </div>
            <h3 class="serif-display text-3xl">La Naissance d'Au Pour Quoi Pas</h3>
          </div>
          <p class="text-lg text-on-surface-variant leading-relaxed">
            Avec ces 20 années d'expérience et une écoute attentive, j'ai pu observer chez les patients un besoin de conseils, d'outils faciles à mettre en place pour améliorer leur quotidien. C'est de là qu'est venue l'idée de créer Au Pour Quoi Pas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Badge -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container-low rounded-[3rem] p-12 md:p-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
        <div>
          <span class="serif-display text-6xl text-primary block mb-4">20+</span>
          <p class="text-on-surface-variant uppercase tracking-widest text-sm font-[Inter]">Années d'expérience</p>
        </div>
        <div>
          <span class="serif-display text-6xl text-primary block mb-4">3</span>
          <p class="text-on-surface-variant uppercase tracking-widest text-sm font-[Inter]">Disciplines complémentaires</p>
        </div>
        <div>
          <span class="serif-display text-6xl text-primary block mb-4">1</span>
          <p class="text-on-surface-variant uppercase tracking-widest text-sm font-[Inter]">Mission : votre bien-être</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy: POUR QUOI PAS -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-16">
      <h2 class="serif-display text-5xl mb-6">La Philosophie</h2>
      <p class="text-on-surface-variant text-xl max-w-2xl mx-auto font-[Newsreader] italic">
        POUR QUOI PAS — trois mots qui portent une invitation à oser, à explorer et à se transformer.
      </p>
    </div>
  </section>

  <PourQuoiPas />

  <!-- CTA -->
  <section class="mx-6 md:mx-12 my-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Envie de faire connaissance ?</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        N'hésitez pas à me contacter pour échanger sur vos besoins et découvrir comment je peux vous accompagner.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Me contacter
      </a>
    </div>
  </section>

</BaseLayout>
