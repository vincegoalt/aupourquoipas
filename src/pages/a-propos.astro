---
import BaseLayout from '../components/BaseLayout.astro';
import PourQuoiPas from '../components/PourQuoiPas.astro';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "name": site.owner.name,
      "jobTitle": site.owner.title,
      "worksFor": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "description": site.owner.shortBio
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "A Propos" }
      ]
    }
  ]
};
---

<BaseLayout
  title="A Propos de Stephanie | Au Pour Quoi Pas"
  description="Podologue posturologue et energeticienne depuis plus de 20 ans, Stephanie vous accompagne vers le bien-etre a Mortagne-au-Perche."
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">A Propos</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <span class="text-sage font-sans text-[10px] tracking-[0.2em] uppercase mb-6 block">Fondatrice</span>
          <h1 class="font-editorial text-[clamp(3rem,5vw,6rem)] text-charcoal leading-[1.05] mb-4 font-light">Stephanie</h1>
          <p class="font-editorial text-xl text-charcoal/50 mb-8">{site.owner.title}</p>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light">
            {site.owner.shortBio}
          </p>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Stephanie, fondatrice d'Au Pour Quoi Pas"
            src="/images/stephanie/portrait.webp"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Full Story -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="max-w-3xl">
          <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Mon parcours</h2>

          <div class="space-y-12">
            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">Enracinee dans le Perche</h3>
              <p class="text-charcoal/60 font-light text-lg leading-relaxed">
                Originaire du Perche, j'ai toujours vecu proche de la nature. Toute mon enfance jusqu'a l'age de 22 ans, j'ai grandi dans l'univers du sport — la course a pied de maniere intense — avec une premiere decouverte du corps et ses blessures.
              </p>
            </div>

            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">Du soin a la posturologie</h3>
              <p class="text-charcoal/60 font-light text-lg leading-relaxed">
                Mes etudes m'ont amenee vers le soin — d'abord Pedicure-Podologue, puis Posturologue, ou j'ai decouvert une approche plus holistique pour traiter les douleurs chroniques.
              </p>
            </div>

            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">La reflexion fondatrice</h3>
              <p class="text-charcoal/60 font-light text-lg leading-relaxed mb-6">
                De ces douleurs chroniques s'est posee la reflexion de la posture et des emotions : qu'est-ce que le corps veut nous dire a travers ces douleurs et maladies ?
              </p>
              <blockquote class="border-l border-terracotta/30 pl-8 py-2">
                <p class="font-editorial italic text-2xl text-charcoal/70">
                  &laquo; Qu'est-ce que le corps veut nous dire a travers ces douleurs et maladies ? &raquo;
                </p>
              </blockquote>
            </div>

            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">Vers l'energetique</h3>
              <p class="text-charcoal/60 font-light text-lg leading-relaxed">
                Aujourd'hui, en plus de mon metier de Podologue Posturologue, je propose des soins energetiques qui travaillent sur la memoire cellulaire du corps pour l'aider a liberer des blocages energetiques et emotionnels.
              </p>
            </div>

            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">La naissance d'Au Pour Quoi Pas</h3>
              <p class="text-charcoal/60 font-light text-lg leading-relaxed">
                Avec ces 20 annees d'experience et une ecoute attentive, j'ai pu observer chez les patients un besoin de conseils, d'outils faciles a mettre en place pour ameliorer leur quotidien. C'est de la qu'est venue l'idee de creer Au Pour Quoi Pas.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Numbers -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 reveal">
        <div class="flex flex-col md:flex-row text-center divide-y md:divide-y-0 md:divide-x divide-charcoal/5">
          <div class="flex-1 py-8 md:py-0 md:px-12">
            <span class="font-editorial text-6xl font-light text-charcoal block mb-3">20+</span>
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">Annees d'experience</span>
          </div>
          <div class="flex-1 py-8 md:py-0 md:px-12">
            <span class="font-editorial text-6xl font-light text-charcoal block mb-3">3</span>
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">Disciplines complementaires</span>
          </div>
          <div class="flex-1 py-8 md:py-0 md:px-12">
            <span class="font-editorial text-6xl font-light text-charcoal block mb-3">1</span>
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">Mission : votre bien-etre</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="py-16 lg:py-24 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-3xl mb-4 font-light">La philosophie</h2>
        <p class="text-charcoal/50 font-light text-lg max-w-xl mx-auto">
          POUR QUOI PAS — trois mots qui portent une invitation a oser, a explorer et a se transformer.
        </p>
      </div>
    </section>

    <PourQuoiPas />

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Envie de faire connaissance ?</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          Me contacter
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
