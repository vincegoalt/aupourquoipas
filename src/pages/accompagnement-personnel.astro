---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('accompagnement-personnel')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": service.shortName }
      ]
    }
  ]
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">{service.shortName}</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light">
            {service.heroHeading}
          </h1>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light mb-8">
            {service.heroSubtitle}
          </p>
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Demander un devis &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Accompagnement personnalise"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1200&q=80"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Origin -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="max-w-3xl reveal">
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-6">La genese</span>
          <h2 class="font-editorial text-3xl lg:text-4xl mb-8 font-light">Un parcours sur-mesure</h2>
          <div class="space-y-6 text-charcoal/60 font-light text-lg leading-relaxed">
            <p>
              L'accompagnement personnel est ne d'une observation simple : les outils les plus puissants ne fonctionnent que s'ils sont adaptes a la personne. En combinant respiration, coherence cardiaque, soins energetiques et outils de gestion du stress, nous creons un parcours unique qui vous ressemble.
            </p>
            <p>
              L'objectif n'est pas de vous rendre dependant d'un accompagnement, mais de vous challenger a depasser vos peurs et vos blocages, tout en vous aidant a trouver vos propres outils pour le quotidien.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Approaches -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Une approche integrative</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
          {[
            { title: "Respiration", desc: "Techniques de coherence cardiaque et de respiration consciente adaptees a vos besoins." },
            { title: "Soins Energetiques", desc: "Travail sur la memoire cellulaire pour liberer les blocages profonds." },
            { title: "Outils Bien-Etre", desc: "Huiles essentielles, relaxation, visualisation : un kit personnalise pour votre quotidien." },
            { title: "Ecoute & Guidance", desc: "Un espace de parole bienveillant pour clarifier vos objectifs et lever les resistances." },
          ].map((item) => (
            <div class="reveal">
              <h3 class="font-editorial text-xl mb-3">{item.title}</h3>
              <p class="text-charcoal/50 font-light text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Le parcours</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
          {[
            { num: "01", title: "Premier Echange", desc: "Un temps d'ecoute approfondi pour comprendre votre situation, vos objectifs et vos besoins. Ensemble, nous definissons un parcours adapte." },
            { num: "02", title: "Parcours Sur-Mesure", desc: "Des seances regulieres combinant differentes approches selon votre progression. Le rythme est ajuste au fil de votre evolution." },
            { num: "03", title: "Autonomie", desc: "L'objectif final : vous donner les outils pour etre autonome au quotidien. Vous repartez avec un kit personnalise de pratiques." },
          ].map((step) => (
            <div class="reveal">
              <span class="text-terracotta/30 font-editorial text-4xl block mb-3">{step.num}</span>
              <h3 class="font-editorial text-xl mb-3">{step.title}</h3>
              <p class="text-charcoal/50 font-light leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-8 font-light reveal">Tarif</h2>
        <p class="text-charcoal/50 font-light text-lg leading-relaxed mb-10 max-w-2xl reveal">
          Chaque accompagnement est unique et combine differentes approches selon vos besoins. Le devis est etabli apres notre premier echange, en fonction du parcours defini ensemble.
        </p>
        <div class="border border-charcoal/5 rounded-lg p-10 inline-block reveal">
          <span class="font-editorial text-3xl block mb-4">Sur devis</span>
          <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
            Demander un devis
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Questions frequentes</h2>
        <div class="max-w-3xl reveal">
          <FAQAccordion faqs={service.faqs} />
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl mb-12 font-light reveal">Les approches qui composent votre parcours</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 reveal">
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-respiration-coherence-cardiaque/">
            <h3 class="font-editorial text-lg mb-2 group-hover:text-terracotta transition-colors">Respiration & Coherence</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-thematiques/">
            <h3 class="font-editorial text-lg mb-2 group-hover:text-terracotta transition-colors">Ateliers Thematiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/soins-energetiques/">
            <h3 class="font-editorial text-lg mb-2 group-hover:text-terracotta transition-colors">Soins Energetiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/reflexologie-plantaire/">
            <h3 class="font-editorial text-lg mb-2 group-hover:text-terracotta transition-colors">Reflexologie Plantaire</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Pret(e) pour votre metamorphose ?</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          Prendre contact
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
