---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('accompagnement-personnel')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": service.shortName }
      ]
    }
  ]
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">{service.shortName}</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">{service.heroHeading}</h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        {service.heroSubtitle}
      </p>
      <div class="pt-4">
        <a href="/contact/" class="inline-block px-10 py-5 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10">
          Demander un devis
        </a>
      </div>
    </div>
    <div class="relative group">
      <div class="absolute inset-0 bg-secondary/5 rounded-[4rem] -rotate-3 scale-105 group-hover:rotate-0 transition-transform duration-700"></div>
      <img
        alt="Accompagnement personnalisé dans un cadre intime et bienveillant"
        class="relative w-full aspect-[4/5] object-cover rounded-[3.5rem] shadow-2xl"
        src="/images/services/accompagnement-personnel.webp"
        width="600"
        height="750"
        loading="eager"
      />
    </div>
  </section>

  <!-- Origin Story -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-10">
        <span class="material-symbols-outlined text-[12rem]">verified</span>
      </div>
      <div class="relative z-10 max-w-3xl">
        <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-[Inter] tracking-widest uppercase mb-6">La Genèse</span>
        <h2 class="serif-display text-5xl md:text-6xl mb-10 leading-tight">
          Né du « Weekend Métamorphose »
        </h2>
        <div class="space-y-6 text-lg text-on-surface-variant leading-relaxed">
          <p>
            L'accompagnement personnel est né d'une observation simple : les outils les plus puissants ne fonctionnent que s'ils sont <strong class="text-on-surface">adaptés à la personne</strong>. En combinant respiration, cohérence cardiaque, soins énergétiques et outils de gestion du stress, nous créons un parcours unique qui vous ressemble.
          </p>
          <p>
            L'objectif n'est pas de vous rendre dépendant d'un accompagnement, mais de vous <strong class="text-on-surface">challenger à dépasser vos peurs et vos blocages</strong>, tout en vous aidant à trouver vos propres outils pour le quotidien. C'est un chemin vers l'autonomie.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Combined Approaches -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Une Approche Intégrative</h2>
      <p class="text-on-surface-variant text-lg max-w-2xl mx-auto">Votre accompagnement puise dans l'ensemble de nos compétences pour créer un parcours sur-mesure.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { icon: "air", title: "Respiration", desc: "Techniques de cohérence cardiaque et de respiration consciente adaptées à vos besoins." },
        { icon: "energy_savings_leaf", title: "Soins Énergétiques", desc: "Travail sur la mémoire cellulaire pour libérer les blocages profonds." },
        { icon: "spa", title: "Outils Bien-Être", desc: "Huiles essentielles, relaxation, visualisation : un kit personnalisé pour votre quotidien." },
        { icon: "psychology", title: "Écoute & Guidance", desc: "Un espace de parole bienveillant pour clarifier vos objectifs et lever les résistances." },
      ].map((item) => (
        <div class="bg-surface-container-low p-8 rounded-[2rem] text-center group hover:bg-surface-container-high transition-colors duration-500">
          <div class="w-16 h-16 rounded-full bg-surface-container-high mx-auto flex items-center justify-center group-hover:bg-primary/5 transition-colors duration-500 mb-4">
            <span class="material-symbols-outlined text-3xl text-primary">{item.icon}</span>
          </div>
          <h3 class="serif-display text-xl mb-3">{item.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Le Parcours</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      {[
        { icon: "chat", title: "1. Premier Échange", desc: "Un temps d'écoute approfondi pour comprendre votre situation, vos objectifs et vos besoins. Ensemble, nous définissons un parcours adapté." },
        { icon: "route", title: "2. Parcours Sur-Mesure", desc: "Des séances régulières combinant différentes approches selon votre progression. Le rythme est ajusté au fil de votre évolution." },
        { icon: "emoji_events", title: "3. Autonomie", desc: "L'objectif final : vous donner les outils pour être autonome au quotidien. Vous repartez avec un kit personnalisé de pratiques." },
      ].map((step) => (
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 rounded-full bg-surface-container-high mx-auto flex items-center justify-center group-hover:bg-primary/5 transition-colors duration-500">
            <span class="material-symbols-outlined text-4xl text-primary">{step.icon}</span>
          </div>
          <h3 class="serif-display text-3xl">{step.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container-low rounded-[3rem] p-12 md:p-20 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="serif-display text-5xl mb-6">Investissement</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
          Chaque accompagnement est unique et combine différentes approches selon vos besoins. Le devis est établi après notre premier échange, en fonction du parcours défini ensemble.
        </p>
        <div class="flex items-center gap-4 text-secondary">
          <span class="material-symbols-outlined">verified</span>
          <span class="text-sm font-[Inter] uppercase tracking-widest">Suivi personnalisé inclus</span>
        </div>
      </div>
      <div class="bg-secondary-container/30 rounded-[2rem] p-12 text-center border border-secondary/10">
        <span class="block text-sm font-[Inter] uppercase tracking-[0.2em] text-secondary mb-4">Tarification</span>
        <span class="serif-display text-5xl text-primary mb-8 block">Sur devis</span>
        <a href="/contact/" class="block w-full py-4 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-xs hover:opacity-90 transition-all text-center">
          Demander un devis
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 md:px-12 mb-32">
    <h2 class="serif-display text-5xl mb-16 text-center italic">Questions Fréquentes</h2>
    <FAQAccordion faqs={service.faqs} />
  </section>

  <!-- CTA -->
  <section class="mx-6 md:mx-12 mb-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    </div>
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Prêt(e) pour votre métamorphose ?</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        Le premier pas est souvent le plus important. Parlons ensemble de votre chemin.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Prendre contact
      </a>
    </div>
  </section>

  <!-- Related Services -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-20">
    <h2 class="serif-display text-4xl mb-12 text-center italic">Les approches qui composent votre parcours</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <a class="group block p-8 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-respiration-coherence-cardiaque/">
        <span class="material-symbols-outlined text-primary mb-4 block text-3xl">air</span>
        <h3 class="serif-display text-xl mb-3">Respiration & Cohérence</h3>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-8 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-thematiques/">
        <span class="material-symbols-outlined text-primary mb-4 block text-3xl">spa</span>
        <h3 class="serif-display text-xl mb-3">Ateliers Thématiques</h3>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-8 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/soins-energetiques/">
        <span class="material-symbols-outlined text-primary mb-4 block text-3xl">energy_savings_leaf</span>
        <h3 class="serif-display text-xl mb-3">Soins Énergétiques</h3>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-8 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/reflexologie-plantaire/">
        <span class="material-symbols-outlined text-primary mb-4 block text-3xl">footprint</span>
        <h3 class="serif-display text-xl mb-3">Réflexologie Plantaire</h3>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
    </div>
  </section>

</BaseLayout>
