---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('ateliers-respiration-coherence-cardiaque')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": service.pricing.map(p => ({
        "@type": "Offer",
        "name": p.label,
        "price": p.price.replace('€', ''),
        "priceCurrency": "EUR"
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Ateliers", "item": `${site.url}/ateliers-respiration-coherence-cardiaque/` },
        { "@type": "ListItem", "position": 3, "name": service.shortName }
      ]
    }
  ]
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><a class="hover:text-primary transition-colors" href="/ateliers-respiration-coherence-cardiaque/">Ateliers</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">{service.shortName}</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">{service.heroHeading}</h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        {service.heroSubtitle}
      </p>
      <div class="pt-4">
        <a href="/contact/" class="inline-block px-10 py-5 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10">
          Réserver votre initiation
        </a>
      </div>
    </div>
    <div class="relative group">
      <div class="absolute inset-0 bg-secondary/5 rounded-[4rem] -rotate-3 scale-105 group-hover:rotate-0 transition-transform duration-700"></div>
      <img
        alt="Séance de cohérence cardiaque dans un espace lumineux et apaisant"
        class="relative w-full aspect-[4/5] object-cover rounded-[3.5rem] shadow-2xl"
        src="/images/services/ateliers-respiration.webp"
        width="600"
        height="750"
        loading="eager"
      />
    </div>
  </section>

  <!-- Science Hook: 5 min = 5h -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-10">
        <span class="material-symbols-outlined text-[12rem]">air</span>
      </div>
      <div class="relative z-10 max-w-3xl">
        <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-[Inter] tracking-widest uppercase mb-6">La Science du Souffle</span>
        <h2 class="serif-display text-5xl md:text-6xl mb-10 leading-tight">
          « 5 minutes de pratique offrent 5 heures de sérénité biologique. »
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {[
            "Réduction de 25 % du taux de cortisol (hormone du stress).",
            "Libération de dopamine, ocytocine, sérotonine et endorphine.",
            "Amélioration de la qualité du sommeil et de la digestion.",
            "Clarté mentale et meilleure gestion émotionnelle.",
          ].map((text) => (
            <div class="flex gap-4">
              <span class="material-symbols-outlined text-primary flex-shrink-0">check_circle</span>
              <p class="text-lg text-on-surface-variant">{text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 3 Steps: Évaluation → Apprentissage → Routine -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Le Chemin vers la Cohérence</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      {[
        { icon: "analytics", title: "1. Évaluation", desc: "Mesure de votre variabilité de fréquence cardiaque (VFC) pour comprendre votre état actuel de stress et votre capacité respiratoire." },
        { icon: "psychology_alt", title: "2. Apprentissage", desc: "Assimilation des techniques respiratoires guidées pour synchroniser cœur et cerveau. La règle du « 365 » : 3 fois par jour, 6 respirations par minute, 5 minutes." },
        { icon: "calendar_today", title: "3. Routine", desc: "Élaboration d'un plan personnalisé pour intégrer ces 5 minutes dans votre quotidien et devenir autonome dans votre pratique." },
      ].map((step) => (
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 rounded-full bg-surface-container-high mx-auto flex items-center justify-center group-hover:bg-primary/5 transition-colors duration-500">
            <span class="material-symbols-outlined text-4xl text-primary">{step.icon}</span>
          </div>
          <h3 class="serif-display text-3xl">{step.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing Block -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32 grid grid-cols-1 md:grid-cols-12 gap-6">
    <div class="md:col-span-12 mb-10">
      <h2 class="serif-display text-5xl">Formats & Investissement</h2>
    </div>

    <!-- Initiation -->
    <div class="md:col-span-8 bg-surface-container-low p-10 rounded-[2.5rem] flex flex-col justify-between">
      <div>
        <h3 class="serif-display text-3xl mb-6">L'Atelier d'Initiation</h3>
        <p class="text-on-surface-variant text-lg mb-8 max-w-lg">
          Une séance immersive d'1h15 pour poser les bases scientifiques et expérimenter les premiers bienfaits. Groupe limité à 8 personnes pour une attention personnalisée.
        </p>
        <div class="flex flex-wrap gap-4 mb-10">
          <span class="px-4 py-2 bg-surface-container-lowest rounded-full border border-outline-variant/10 text-sm font-[Inter] uppercase tracking-widest text-primary">1h15 de session</span>
          <span class="px-4 py-2 bg-surface-container-lowest rounded-full border border-outline-variant/10 text-sm font-[Inter] uppercase tracking-widest text-primary">Maximum 8 pers.</span>
        </div>
      </div>
      <div class="flex flex-col md:flex-row gap-8 items-end justify-between border-t border-outline-variant/10 pt-10">
        <div class="flex gap-10">
          <div>
            <span class="block text-xs uppercase tracking-widest text-on-surface-variant/60 mb-1">Groupe</span>
            <span class="serif-display text-3xl font-light text-primary">30€</span>
          </div>
          <div>
            <span class="block text-xs uppercase tracking-widest text-on-surface-variant/60 mb-1">Individuel</span>
            <span class="serif-display text-3xl font-light text-primary">70€</span>
          </div>
        </div>
        <a href="/contact/" class="px-8 py-4 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-xs text-center hover:opacity-90 transition-all">S'inscrire</a>
      </div>
    </div>

    <!-- Forfaits -->
    <div class="md:col-span-4 bg-secondary-container p-10 rounded-[2.5rem] text-on-secondary-container flex flex-col justify-between">
      <div>
        <h3 class="serif-display text-3xl mb-6">Packs Sérénité</h3>
        <p class="text-sm opacity-80 mb-8">Pour ancrer la pratique dans le temps à travers un suivi régulier.</p>
        <ul class="space-y-4 mb-10">
          <li class="flex justify-between items-center pb-2 border-b border-on-secondary-container/10">
            <span>Forfait 5 séances</span>
            <span class="serif-display text-2xl font-light">80€</span>
          </li>
          <li class="flex justify-between items-center pb-2 border-b border-on-secondary-container/10">
            <span>Forfait 10 séances</span>
            <span class="serif-display text-2xl font-light">140€</span>
          </li>
        </ul>
      </div>
      <a href="/contact/" class="block w-full py-4 bg-on-secondary-container text-secondary-container rounded-full font-[Inter] tracking-widest uppercase text-xs text-center hover:opacity-90 transition-all">Découvrir</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 md:px-12 mb-32">
    <h2 class="serif-display text-5xl mb-16 text-center italic">Questions Fréquentes</h2>
    <FAQAccordion faqs={service.faqs} />
  </section>

  <!-- CTA -->
  <section class="mx-6 md:mx-12 mb-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    </div>
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Prêt(e) à respirer à nouveau ?</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        Rejoignez-nous pour une session d'initiation et commencez votre voyage vers une vie plus sereine.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Réserver votre séance d'initiation
      </a>
    </div>
  </section>

  <!-- Related Services -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-20">
    <h2 class="serif-display text-4xl mb-12 text-center italic">Explorer d'autres soins</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-thematiques/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">spa</span>
        <h3 class="serif-display text-2xl mb-4">Ateliers Thématiques</h3>
        <p class="text-on-surface-variant text-sm mb-6">Des moments de partage autour du bien-être et de la connaissance de soi.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/soins-energetiques/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">energy_savings_leaf</span>
        <h3 class="serif-display text-2xl mb-4">Soins Énergétiques</h3>
        <p class="text-on-surface-variant text-sm mb-6">Réalignez vos centres d'énergie pour une vitalité retrouvée.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/reflexologie-plantaire/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">footprint</span>
        <h3 class="serif-display text-2xl mb-4">Réflexologie Plantaire</h3>
        <p class="text-on-surface-variant text-sm mb-6">Une approche ancestrale pour libérer les tensions du corps.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
    </div>
  </section>

</BaseLayout>
