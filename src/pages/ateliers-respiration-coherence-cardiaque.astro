---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('ateliers-respiration-coherence-cardiaque')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": service.pricing.map(p => ({
        "@type": "Offer",
        "name": p.label,
        "price": p.price.replace('€', ''),
        "priceCurrency": "EUR"
      }))
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Ateliers", "item": `${site.url}/ateliers-respiration-coherence-cardiaque/` },
        { "@type": "ListItem", "position": 3, "name": service.shortName }
      ]
    }
  ]
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">{service.shortName}</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light">
            {service.heroHeading}
          </h1>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light mb-8">
            {service.heroSubtitle}
          </p>
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Reserver votre initiation &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Seance de coherence cardiaque"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="https://images.unsplash.com/photo-1545389336-cf090694435e?w=1200&q=80"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Science -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="max-w-3xl reveal">
          <p class="font-editorial italic text-3xl lg:text-4xl text-charcoal leading-snug mb-12 font-light">
            &laquo; 5 minutes = 5 heures de serenite biologique. &raquo;
          </p>
          <div class="space-y-6 text-charcoal/60 font-light text-lg leading-relaxed">
            <p>&mdash; Reduction de 25 % du taux de cortisol, l'hormone du stress</p>
            <p>&mdash; Liberation de dopamine, ocytocine, serotonine et endorphine</p>
            <p>&mdash; Amelioration de la qualite du sommeil et de la digestion</p>
            <p>&mdash; Clarte mentale et meilleure gestion emotionnelle</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-16 font-light reveal">Le processus</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
          {[
            { num: "01", title: "Evaluation", desc: "Mesure de votre variabilite de frequence cardiaque pour comprendre votre etat actuel de stress et votre capacite respiratoire." },
            { num: "02", title: "Apprentissage", desc: "Synchronisation du coeur et de l'esprit par des techniques respiratoires guidees. La regle du 365 : 3 fois par jour, 6 respirations par minute, 5 minutes." },
            { num: "03", title: "Routine", desc: "Integration perenne de ce rituel de 5 minutes dans votre quotidien pour devenir autonome dans votre pratique." },
          ].map((step) => (
            <div class="reveal">
              <span class="text-terracotta/30 font-editorial text-5xl block mb-4">{step.num}</span>
              <h3 class="font-editorial text-2xl mb-4">{step.title}</h3>
              <p class="text-charcoal/50 font-light leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-16 font-light reveal">Tarifs</h2>
        <div class="divide-y divide-charcoal/5 reveal">
          <div class="flex justify-between items-baseline py-8">
            <span class="text-charcoal text-lg font-light">Initiation groupe</span>
            <span class="font-editorial text-2xl">30&euro;</span>
          </div>
          <div class="flex justify-between items-baseline py-8">
            <span class="text-charcoal text-lg font-light">Initiation individuel</span>
            <span class="font-editorial text-2xl">70&euro;</span>
          </div>
          <div class="flex justify-between items-baseline py-8">
            <span class="text-charcoal text-lg font-light">Forfait 5 seances</span>
            <span class="font-editorial text-2xl">80&euro;</span>
          </div>
          <div class="flex justify-between items-baseline py-8">
            <span class="text-charcoal text-lg font-light">Forfait 10 seances</span>
            <span class="font-editorial text-2xl">140&euro;</span>
          </div>
        </div>
        <div class="mt-10 reveal">
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Reserver &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-16 font-light reveal">Questions frequentes</h2>
        <div class="max-w-3xl reveal">
          <FAQAccordion faqs={service.faqs} />
        </div>
      </div>
    </section>

    <!-- Related Services -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl mb-12 font-light reveal">Explorer d'autres soins</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-thematiques/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Ateliers Thematiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/soins-energetiques/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Soins Energetiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/reflexologie-plantaire/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Reflexologie Plantaire</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Pret(e) a respirer ?</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          Reserver votre initiation
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
