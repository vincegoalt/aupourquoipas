---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('ateliers-thematiques')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": {
        "@type": "Offer",
        "name": "Atelier thematique (2h)",
        "price": "55",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": service.shortName }
      ]
    }
  ]
};

const themes = [
  { title: "Gestion du Stress", desc: "Apprenez a identifier vos declencheurs de stress et a mettre en place des strategies concretes pour retrouver le calme." },
  { title: "Booster son Energie", desc: "Decouvrez comment relancer votre vitalite grace a des exercices respiratoires, des huiles essentielles et des routines simples." },
  { title: "Reguler ses Emotions", desc: "Comprenez le lien entre vos emotions et votre corps pour mieux les accueillir et les traverser en douceur." },
  { title: "Clarte Mentale", desc: "Dispersez le brouillard cerebral grace a des techniques de visualisation et de respiration ciblees." },
];
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">{service.shortName}</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light">
            {service.heroHeading}
          </h1>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light mb-6">
            {service.heroSubtitle}
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">2h par atelier</span>
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">&middot; 6-8 personnes</span>
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase">&middot; Trimestriel</span>
          </div>
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Reserver un atelier &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Atelier thematique bien-etre en groupe"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?w=1200&q=80"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Themes -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Les thematiques</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12">
          {themes.map((theme) => (
            <div class="reveal">
              <h3 class="font-editorial text-2xl mb-4">{theme.title}</h3>
              <p class="text-charcoal/50 font-light leading-relaxed">{theme.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tools -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Les outils que vous repartez avec</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
          {[
            { title: "Huiles essentielles", desc: "Decouverte et utilisation d'huiles essentielles adaptees a chaque thematique." },
            { title: "Exercices de detente", desc: "Techniques de relaxation corporelle et respiratoire a reproduire chez soi." },
            { title: "Visualisation guidee", desc: "Exercices de visualisation pour ancrer les apprentissages et developper vos ressources interieures." },
          ].map((tool) => (
            <div class="reveal">
              <h3 class="font-editorial text-xl mb-3">{tool.title}</h3>
              <p class="text-charcoal/50 font-light text-sm leading-relaxed">{tool.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-12 font-light reveal">Tarif</h2>
        <div class="border-t border-charcoal/5 reveal">
          <div class="flex justify-between items-baseline py-8">
            <div>
              <span class="text-charcoal text-lg font-light block">Atelier thematique</span>
              <span class="text-charcoal/40 text-sm">2h &middot; 6-8 personnes</span>
            </div>
            <span class="font-editorial text-3xl">55&euro;</span>
          </div>
        </div>
        <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Reserver &rarr;</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Questions frequentes</h2>
        <div class="max-w-3xl reveal">
          <FAQAccordion faqs={service.faqs} />
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl mb-12 font-light reveal">Explorer d'autres soins</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-respiration-coherence-cardiaque/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Respiration & Coherence</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/soins-energetiques/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Soins Energetiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/accompagnement-personnel/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Accompagnement Personnel</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Envie de decouvrir un theme ?</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          S'inscrire au prochain atelier
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
