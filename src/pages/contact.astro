---
import BaseLayout from '../components/BaseLayout.astro';
import { services } from '../data/services';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "name": "Contact — Au Pour Quoi Pas",
      "url": `${site.url}/contact/`,
      "mainEntity": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "email": site.email,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": site.address.street,
          "addressLocality": site.address.city,
          "postalCode": site.address.postalCode,
          "addressCountry": "FR"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Contact" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Contact | Au Pour Quoi Pas — Mortagne-au-Perche"
  description="Contactez Au Pour Quoi Pas pour reserver un atelier ou poser vos questions. 44 rue Montcacune, Mortagne-au-Perche. aupourquoipas61@gmail.com"
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">Contact</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-20">
      <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-6 font-light reveal">
        Parlons de votre serenite
      </h1>
      <p class="max-w-lg text-charcoal/60 text-lg leading-relaxed font-light reveal">
        Un moment suspendu, une respiration partagee. Nos services s'adaptent a votre quete de calme interieur.
      </p>
    </header>

    <!-- Content -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20">

        <!-- Form -->
        <div class="lg:col-span-7 reveal">
          <form class="space-y-8" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div>
                <label for="nom" class="text-[10px] font-sans uppercase tracking-[0.2em] text-charcoal/40 block mb-2">Votre nom</label>
                <input id="nom" name="nom" type="text" required placeholder="Nom complet" class="input-underline" />
              </div>
              <div>
                <label for="email" class="text-[10px] font-sans uppercase tracking-[0.2em] text-charcoal/40 block mb-2">Email</label>
                <input id="email" name="email" type="email" required placeholder="votre@adresse.com" class="input-underline" />
              </div>
            </div>

            <div>
              <label for="telephone" class="text-[10px] font-sans uppercase tracking-[0.2em] text-charcoal/40 block mb-2">Telephone</label>
              <input id="telephone" name="telephone" type="tel" placeholder="+33 6 00 00 00 00" class="input-underline" />
            </div>

            <div>
              <label for="service" class="text-[10px] font-sans uppercase tracking-[0.2em] text-charcoal/40 block mb-2">Service souhaite</label>
              <select id="service" name="service" class="input-underline appearance-none cursor-pointer">
                <option value="">Choisir un service</option>
                {services.map((s) => (
                  <option value={s.slug}>{s.name}</option>
                ))}
                <option value="location-salle">Location de salle</option>
                <option value="autre">Autre demande</option>
              </select>
            </div>

            <div>
              <label for="message" class="text-[10px] font-sans uppercase tracking-[0.2em] text-charcoal/40 block mb-2">Votre message</label>
              <textarea id="message" name="message" rows="4" required placeholder="Decrivez vos attentes..." class="input-underline resize-none"></textarea>
            </div>

            <button type="submit" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
              Envoyer
            </button>
          </form>
        </div>

        <!-- Info + Map -->
        <div class="lg:col-span-5 reveal">
          <div class="space-y-10 mb-12">
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Adresse</span>
              <p class="text-charcoal/70 font-light text-lg">{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
            </div>
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Horaires</span>
              <ul class="text-charcoal/70 font-light text-lg space-y-1">
                {site.schedule.map((s) => (
                  <li>{s.day} : {s.time}{s.note ? ` (${s.note})` : ''}</li>
                ))}
              </ul>
              <p class="text-sage text-sm mt-2">Uniquement sur reservation</p>
            </div>
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Email</span>
              <a class="text-terracotta hover:text-terracotta/70 transition-colors link-underline text-lg" href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </div>

          <div class="h-[350px] rounded-lg overflow-hidden">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2600!2d0.5478!3d48.5206!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s44+rue+Montcacune+Mortagne-au-Perche!5e0!3m2!1sfr!2sfr!4v1"
              width="100%"
              height="100%"
              style="border:0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Carte — Au Pour Quoi Pas, 44 rue Montcacune, Mortagne-au-Perche"
            ></iframe>
          </div>
        </div>

      </div>
    </section>

  </div>

</BaseLayout>
