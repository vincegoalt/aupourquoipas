---
import BaseLayout from '../components/BaseLayout.astro';
import PourQuoiPas from '../components/PourQuoiPas.astro';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@type": "HealthAndWellnessBusiness",
  "name": site.name,
  "description": site.description,
  "url": site.url,
  "email": site.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "postalCode": site.address.postalCode,
    "addressRegion": site.address.region,
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": site.geo.lat,
    "longitude": site.geo.lng
  },
  "areaServed": [
    { "@type": "City", "name": "Mortagne-au-Perche" },
    { "@type": "AdministrativeArea", "name": "Orne" },
    { "@type": "AdministrativeArea", "name": "Perche" }
  ],
  "priceRange": "30€ - 70€",
  "inLanguage": "fr"
};
---

<BaseLayout
  title="Coherence Cardiaque & Respiration a Mortagne-au-Perche | Au Pour Quoi Pas"
  description="Regulez votre stress grace a la respiration et la coherence cardiaque. Ateliers, soins energetiques et reflexologie plantaire a Mortagne-au-Perche. Des 30€."
  schema={schema}
>

  <!-- 1. HERO -->
  <header class="pt-32 lg:pt-40 pb-32 lg:pb-48 border-b border-charcoal/5">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <span class="text-sage font-sans text-[10px] tracking-[0.2em] uppercase mb-8 block">Coherence cardiaque · Mortagne-au-Perche</span>
          <h1 class="font-editorial text-[clamp(3rem,5vw,7rem)] text-charcoal leading-[1.05] mb-8 font-light">
            Retrouvez votre calme interieur
          </h1>
          <p class="max-w-lg text-charcoal/60 text-lg leading-relaxed mb-10 font-light">
            Apprenez a calmer votre mental, retrouver un sommeil profond et harmoniser votre rythme cardiaque au coeur du Perche. Une parenthese de serenite pour soi.
          </p>
          <a href="/ateliers-respiration-coherence-cardiaque/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Decouvrir les ateliers &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Personne pratiquant la respiration consciente dans la nature"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1200&q=80"
            width="600"
            height="800"
          />
        </div>
      </div>
    </div>
  </header>

  <!-- 2. INTRO QUOTE -->
  <section class="py-32 lg:py-48 bg-warm-gray">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
      <p class="font-editorial italic text-3xl lg:text-5xl text-charcoal leading-snug mb-6 max-w-4xl mx-auto font-light">
        &laquo; 5 minutes de respiration consciente suffisent a transformer votre journee. &raquo;
      </p>
      <span class="text-sage text-[10px] tracking-[0.2em] uppercase">&mdash; Valide par les neurosciences</span>
    </div>
  </section>

  <!-- 3. SERVICES -->
  <section class="py-32 lg:py-48 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
        <!-- Service 1 -->
        <a href="/ateliers-respiration-coherence-cardiaque/" class="group reveal">
          <div class="aspect-[16/9] overflow-hidden rounded-lg mb-6">
            <img alt="Atelier de coherence cardiaque" class="w-full h-full object-cover img-editorial group-hover:scale-[1.02] transition-transform duration-700" src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80" width="800" height="450" loading="lazy" />
          </div>
          <h3 class="font-editorial text-2xl mb-3 group-hover:text-terracotta transition-colors duration-300">Respiration & Coherence</h3>
          <p class="text-charcoal/50 font-light text-base mb-4">Initiez-vous aux bases de la coherence cardiaque et integrez des routines simples.</p>
          <span class="text-terracotta text-sm link-underline">En savoir plus &rarr;</span>
        </a>

        <!-- Service 2 (offset) -->
        <a href="/ateliers-thematiques/" class="group md:mt-16 reveal">
          <div class="aspect-[16/9] overflow-hidden rounded-lg mb-6">
            <img alt="Ateliers thematiques bien-etre" class="w-full h-full object-cover img-editorial group-hover:scale-[1.02] transition-transform duration-700" src="https://images.unsplash.com/photo-1608571423902-eed4a5ad8108?w=800&q=80" width="800" height="450" loading="lazy" />
          </div>
          <h3 class="font-editorial text-2xl mb-3 group-hover:text-terracotta transition-colors duration-300">Ateliers Thematiques</h3>
          <p class="text-charcoal/50 font-light text-base mb-4">Stress, emotions, clarte mentale : explorez des besoins specifiques chaque trimestre.</p>
          <span class="text-terracotta text-sm link-underline">En savoir plus &rarr;</span>
        </a>

        <!-- Service 3 -->
        <a href="/soins-energetiques/" class="group reveal">
          <div class="aspect-[16/9] overflow-hidden rounded-lg mb-6">
            <img alt="Seance individuelle de soins" class="w-full h-full object-cover img-editorial group-hover:scale-[1.02] transition-transform duration-700" src="https://images.unsplash.com/photo-1600618528240-fb9fc964b853?w=800&q=80" width="800" height="450" loading="lazy" />
          </div>
          <h3 class="font-editorial text-2xl mb-3 group-hover:text-terracotta transition-colors duration-300">Seances Privees</h3>
          <p class="text-charcoal/50 font-light text-base mb-4">Soins energetiques, reflexologie plantaire et accompagnement personnalise.</p>
          <span class="text-terracotta text-sm link-underline">En savoir plus &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. ABOUT -->
  <section class="py-32 lg:py-48 bg-warm-gray">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <div class="lg:col-span-5 reveal">
          <img
            alt="Stephanie, fondatrice d'Au Pour Quoi Pas"
            src="/images/stephanie/portrait.webp"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            width="500"
            height="667"
            loading="lazy"
          />
        </div>
        <div class="lg:col-span-7 reveal">
          <span class="text-sage font-sans text-[10px] tracking-[0.2em] uppercase mb-6 block">Fondatrice</span>
          <h2 class="font-editorial text-4xl lg:text-5xl mb-8 font-light">Stephanie</h2>
          <p class="text-charcoal/60 text-lg leading-relaxed mb-8 font-light">
            {site.owner.shortBio}
          </p>
          <a href="/a-propos/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            En savoir plus &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. NUMBERS -->
  <section class="py-32 lg:py-48 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24 reveal">
      <div class="flex flex-col md:flex-row text-center divide-y md:divide-y-0 md:divide-x divide-charcoal/5">
        <div class="flex-1 py-8 md:py-0 md:px-12">
          <span class="font-editorial text-6xl lg:text-7xl font-light text-charcoal block mb-3">20+</span>
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase">Annees d'experience</span>
        </div>
        <div class="flex-1 py-8 md:py-0 md:px-12">
          <span class="font-editorial text-6xl lg:text-7xl font-light text-charcoal block mb-3">5 min</span>
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase">De pratique quotidienne</span>
        </div>
        <div class="flex-1 py-8 md:py-0 md:px-12">
          <span class="font-editorial text-6xl lg:text-7xl font-light text-charcoal block mb-3">8 max</span>
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase">Participants par atelier</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. PRICING PREVIEW -->
  <section class="py-32 lg:py-48 bg-warm-gray">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 reveal">
        <div class="border border-charcoal/5 rounded-lg p-10 lg:p-14">
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">A la seance</span>
          <div class="flex justify-between items-baseline mb-4">
            <h3 class="font-editorial text-2xl">Atelier Decouverte</h3>
            <span class="font-editorial text-3xl text-charcoal">30&euro;</span>
          </div>
          <p class="text-charcoal/50 font-light text-sm">1h15 de pratique guidee en petit groupe</p>
        </div>
        <div class="border border-charcoal/5 rounded-lg p-10 lg:p-14">
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Forfait complet</span>
          <div class="flex justify-between items-baseline mb-4">
            <h3 class="font-editorial text-2xl">10 Seances</h3>
            <span class="font-editorial text-3xl text-charcoal">140&euro;</span>
          </div>
          <p class="text-charcoal/50 font-light text-sm">Acces a tous les ateliers respiration + suivi</p>
        </div>
      </div>
      <div class="text-center mt-10 reveal">
        <a href="/tarifs/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
          Tous les tarifs &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- 7. POUR QUOI PAS -->
  <PourQuoiPas />

  <!-- 8. LOCATION -->
  <section class="py-32 lg:py-48 bg-warm-gray">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-start">
        <div class="reveal">
          <h2 class="font-editorial text-4xl lg:text-5xl mb-12 font-light">Nous trouver</h2>
          <div class="space-y-10">
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Adresse</span>
              <p class="text-charcoal/70 font-light text-lg">{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
            </div>
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Horaires</span>
              <ul class="text-charcoal/70 font-light text-lg space-y-1">
                {site.schedule.map((s) => (
                  <li>{s.day} : {s.time}{s.note ? ` (${s.note})` : ''}</li>
                ))}
              </ul>
              <p class="text-sage text-sm mt-3">Uniquement sur reservation</p>
            </div>
            <div>
              <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-3">Email</span>
              <a class="text-terracotta hover:text-terracotta/70 transition-colors link-underline text-lg" href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </div>
        </div>
        <div class="h-[450px] rounded-lg overflow-hidden reveal">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2600!2d0.5478!3d48.5206!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s44+rue+Montcacune+Mortagne-au-Perche!5e0!3m2!1sfr!2sfr!4v1"
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Carte — Au Pour Quoi Pas, 44 rue Montcacune, Mortagne-au-Perche"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. CTA -->
  <section class="py-32 lg:py-48 bg-warm-white">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
      <h2 class="font-editorial text-4xl lg:text-6xl mb-10 font-light">Pret(e) a respirer ?</h2>
      <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
        Reserver un atelier
      </a>
    </div>
  </section>

</BaseLayout>
