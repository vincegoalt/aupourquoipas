---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Place",
      "name": "L'Atelier — Au Pour Quoi Pas",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.address.street,
        "addressLocality": site.address.city,
        "postalCode": site.address.postalCode,
        "addressCountry": "FR"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Location de Salle" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Location de Salle | Au Pour Quoi Pas"
  description="Louez notre espace bien-etre au 44 rue Montcacune a Mortagne-au-Perche. Ideal pour ateliers, formations et pratiques de groupe."
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">Location de Salle</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <span class="text-sage font-sans text-[10px] tracking-[0.2em] uppercase mb-6 block">Un espace pour vos projets</span>
          <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light">
            Location de Salle
          </h1>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light mb-8">
            Un espace chaleureux et apaisant au coeur de Mortagne-au-Perche, ideal pour vos ateliers, formations et pratiques de bien-etre.
          </p>
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Nous contacter &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Salle lumineuse a louer pour ateliers"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="/images/lieu/practice-room.webp"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- L'Espace -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="max-w-3xl reveal">
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-6">L'espace</span>
          <h2 class="font-editorial text-3xl lg:text-4xl mb-8 font-light">Un lieu pense pour le bien-etre</h2>
          <div class="space-y-6 text-charcoal/60 font-light text-lg leading-relaxed">
            <p>
              Situe au 44 rue Montcacune a Mortagne-au-Perche, notre espace est un lieu lumineux, calme et chaleureux. L'ambiance a ete pensee pour favoriser la detente et le partage.
            </p>
            <p>
              Que vous soyez praticien bien-etre, formateur, coach ou animateur d'ateliers, cet espace s'adapte a vos besoins pour accueillir vos evenements dans les meilleures conditions.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Caracteristiques</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-16 gap-y-12">
          {[
            { title: "Capacite", desc: "Jusqu'a 8 personnes en configuration atelier. Ideal pour les petits groupes et les formations intimistes." },
            { title: "Equipement", desc: "Chaises, tapis de sol, coussins de meditation, table. Materiel de base fourni pour vos ateliers." },
            { title: "Connectivite", desc: "Acces Wi-Fi disponible. Espace adapte pour les presentations et les supports numeriques." },
            { title: "Accessibilite", desc: "Stationnement facile a proximite. Acces au centre-ville de Mortagne-au-Perche." },
            { title: "Confort", desc: "Espace chauffe, lumineux, avec acces a un point d'eau. Ambiance soignee et apaisante." },
            { title: "Disponibilite", desc: "Location a la demi-journee ou a la journee. Contactez-nous pour verifier les creneaux." },
          ].map((item) => (
            <div class="reveal">
              <h3 class="font-editorial text-xl mb-3">{item.title}</h3>
              <p class="text-charcoal/50 font-light text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <div class="reveal">
            <h2 class="font-editorial text-3xl lg:text-4xl mb-8 font-light">Tarification</h2>
            <p class="text-charcoal/50 font-light text-lg leading-relaxed mb-6">
              Les tarifs varient selon la duree et la frequence de reservation. Contactez-nous pour un devis personnalise.
            </p>
            <ul class="space-y-3 text-charcoal/60 font-light">
              <li>&mdash; Location a la demi-journee ou a la journee</li>
              <li>&mdash; Tarifs degressifs pour les reservations regulieres</li>
              <li>&mdash; Materiel de base inclus</li>
            </ul>
          </div>
          <div class="border border-charcoal/5 rounded-lg p-10 text-center reveal">
            <span class="font-editorial text-3xl block mb-6">Sur devis</span>
            <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
              Demander un devis
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Location -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          <div class="reveal">
            <h2 class="font-editorial text-3xl mb-8 font-light">Localisation</h2>
            <div class="space-y-6">
              <div>
                <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-2">Adresse</span>
                <p class="text-charcoal/70 font-light text-lg">{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
              </div>
              <div>
                <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-2">Contact</span>
                <a href={`mailto:${site.email}`} class="text-terracotta hover:text-terracotta/70 transition-colors link-underline text-lg">{site.email}</a>
              </div>
            </div>
          </div>
          <div class="h-[400px] rounded-lg overflow-hidden reveal">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2600!2d0.5478!3d48.5206!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s44+rue+Montcacune+Mortagne-au-Perche!5e0!3m2!1sfr!2sfr!4v1"
              width="100%"
              height="100%"
              style="border:0"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Carte — Au Pour Quoi Pas, 44 rue Montcacune, Mortagne-au-Perche"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Interesse(e) par notre espace ?</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          Nous contacter
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
