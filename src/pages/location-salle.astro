---
import BaseLayout from '../components/BaseLayout.astro';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Place",
      "name": "L'Atelier — Au Pour Quoi Pas",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": site.address.street,
        "addressLocality": site.address.city,
        "postalCode": site.address.postalCode,
        "addressCountry": "FR"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Location de Salle" }
      ]
    }
  ]
};
---

<BaseLayout
  title="Location de Salle | Au Pour Quoi Pas"
  description="Louez notre espace bien-être au 44 rue Montcacune à Mortagne-au-Perche. Idéal pour ateliers, formations et pratiques de groupe."
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">Location de Salle</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <span class="text-secondary font-[Inter] text-sm tracking-[0.3em] uppercase block">Un espace pour vos projets</span>
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">Location de Salle</h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        Un espace chaleureux et apaisant au cœur de Mortagne-au-Perche, idéal pour vos ateliers, formations et pratiques de bien-être.
      </p>
      <div class="pt-4">
        <a href="/contact/" class="inline-block px-10 py-5 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10">
          Nous contacter
        </a>
      </div>
    </div>
    <div class="relative group">
      <div class="absolute inset-0 bg-secondary/5 rounded-[4rem] -rotate-3 scale-105 group-hover:rotate-0 transition-transform duration-700"></div>
      <img
        alt="Salle lumineuse et chaleureuse à louer pour ateliers bien-être"
        class="relative w-full aspect-[4/5] object-cover rounded-[3.5rem] shadow-2xl"
        src="/images/atelier/salle-location.webp"
        width="600"
        height="750"
        loading="eager"
      />
    </div>
  </section>

  <!-- L'Espace -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-10">
        <span class="material-symbols-outlined text-[12rem]">meeting_room</span>
      </div>
      <div class="relative z-10 max-w-3xl">
        <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-[Inter] tracking-widest uppercase mb-6">L'Espace</span>
        <h2 class="serif-display text-5xl md:text-6xl mb-10 leading-tight">
          Un lieu pensé pour le bien-être
        </h2>
        <div class="space-y-6 text-lg text-on-surface-variant leading-relaxed">
          <p>
            Situé au <strong class="text-on-surface">44 rue Montcacune à Mortagne-au-Perche</strong>, notre espace est un lieu lumineux, calme et chaleureux. L'ambiance a été pensée pour favoriser la détente et le partage.
          </p>
          <p>
            Que vous soyez praticien bien-être, formateur, coach ou animateur d'ateliers, cet espace s'adapte à vos besoins pour accueillir vos événements dans les meilleures conditions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Caractéristiques -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Caractéristiques</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        { icon: "groups", title: "Capacité", desc: "Jusqu'à 8 personnes en configuration atelier. Idéal pour les petits groupes et les formations intimistes." },
        { icon: "chair", title: "Équipement", desc: "Chaises, tapis de sol, coussins de méditation, table. Matériel de base fourni pour vos ateliers." },
        { icon: "wifi", title: "Connectivité", desc: "Accès Wi-Fi disponible. Espace adapté pour les présentations et les supports numériques." },
        { icon: "local_parking", title: "Accessibilité", desc: "Stationnement facile à proximité. Accès au centre-ville de Mortagne-au-Perche." },
        { icon: "water_drop", title: "Confort", desc: "Espace chauffé, lumineux, avec accès à un point d'eau. Ambiance soignée et apaisante." },
        { icon: "calendar_month", title: "Disponibilité", desc: "Location à la demi-journée ou à la journée. Contactez-nous pour vérifier les créneaux disponibles." },
      ].map((item) => (
        <div class="bg-surface-container-low p-8 rounded-[2rem] group hover:bg-surface-container-high transition-colors duration-500">
          <span class="material-symbols-outlined text-3xl text-primary mb-4 block">{item.icon}</span>
          <h3 class="serif-display text-xl mb-3">{item.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing & Contact -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container-low rounded-[3rem] p-12 md:p-20 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="serif-display text-5xl mb-6">Tarification</h2>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
          Les tarifs de location varient selon la durée et la fréquence de réservation. Contactez-nous pour obtenir un devis personnalisé adapté à vos besoins.
        </p>
        <ul class="space-y-3 text-on-surface-variant">
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary">check</span>
            Location à la demi-journée ou à la journée
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary">check</span>
            Tarifs dégressifs pour les réservations régulières
          </li>
          <li class="flex items-center gap-3">
            <span class="material-symbols-outlined text-secondary">check</span>
            Matériel de base inclus
          </li>
        </ul>
      </div>
      <div class="bg-secondary-container/30 rounded-[2rem] p-12 text-center border border-secondary/10">
        <span class="block text-sm font-[Inter] uppercase tracking-[0.2em] text-secondary mb-4">Tarification</span>
        <span class="serif-display text-4xl text-primary mb-4 block">Sur devis</span>
        <p class="text-on-surface-variant text-sm mb-8">Contactez-nous pour connaître les disponibilités et obtenir un devis.</p>
        <a href="/contact/" class="block w-full py-4 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-xs hover:opacity-90 transition-all text-center">
          Demander un devis
        </a>
      </div>
    </div>
  </section>

  <!-- Location Info -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="serif-display text-4xl mb-8">Localisation</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-6">
            <span class="material-symbols-outlined text-primary text-3xl">location_on</span>
            <div>
              <p class="font-bold text-lg mb-1">L'Atelier</p>
              <p class="text-on-surface-variant text-lg">{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <span class="material-symbols-outlined text-primary text-3xl">mail</span>
            <div>
              <p class="font-bold text-lg mb-1">Contact</p>
              <a href={`mailto:${site.email}`} class="text-on-surface-variant text-lg hover:text-primary transition-colors">{site.email}</a>
            </div>
          </div>
        </div>
      </div>
      <div class="h-[400px] rounded-[3rem] overflow-hidden shadow-sm">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2600!2d0.5478!3d48.5206!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s44+rue+Montcacune+Mortagne-au-Perche!5e0!3m2!1sfr!2sfr!4v1"
          width="100%"
          height="100%"
          style="border:0"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Carte — Au Pour Quoi Pas, 44 rue Montcacune, Mortagne-au-Perche"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-6 md:mx-12 mb-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Intéressé(e) par notre espace ?</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        Contactez-nous pour visiter l'espace et discuter de votre projet.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Nous contacter
      </a>
    </div>
  </section>

</BaseLayout>
