---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('reflexologie-plantaire')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": {
        "@type": "Offer",
        "name": "Séance individuelle",
        "price": "65",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Soins", "item": `${site.url}/reflexologie-plantaire/` },
        { "@type": "ListItem", "position": 3, "name": service.shortName }
      ]
    }
  ]
};

const benefits = [
  { icon: "spa", title: "Réduction du Stress", desc: "La stimulation des zones réflexes active le système parasympathique et apporte une relaxation profonde." },
  { icon: "bedtime", title: "Meilleur Sommeil", desc: "En rétablissant l'équilibre nerveux, la réflexologie favorise un endormissement plus rapide et un sommeil réparateur." },
  { icon: "restaurant", title: "Digestion Améliorée", desc: "Les zones réflexes liées au système digestif aident à réguler les troubles fonctionnels." },
  { icon: "bolt", title: "Regain d'Énergie", desc: "En libérant les blocages, l'énergie circule à nouveau librement dans tout le corps." },
  { icon: "healing", title: "Soulagement des Douleurs", desc: "Les tensions musculaires et certaines douleurs chroniques peuvent être soulagées par la réflexologie." },
  { icon: "self_improvement", title: "Équilibre Émotionnel", desc: "Le pied est un miroir du corps : en travaillant les zones réflexes, on harmonise aussi les émotions." },
];
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><a class="hover:text-primary transition-colors" href="/reflexologie-plantaire/">Soins</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">{service.shortName}</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">{service.heroHeading}</h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        {service.heroSubtitle}
      </p>
      <div class="pt-4">
        <a href="/contact/" class="inline-block px-10 py-5 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10">
          Prendre rendez-vous
        </a>
      </div>
    </div>
    <div class="relative group">
      <div class="absolute inset-0 bg-secondary/5 rounded-[4rem] -rotate-3 scale-105 group-hover:rotate-0 transition-transform duration-700"></div>
      <img
        alt="Séance de réflexologie plantaire dans un cadre chaleureux"
        class="relative w-full aspect-[4/5] object-cover rounded-[3.5rem] shadow-2xl"
        src="/images/services/reflexologie-plantaire.webp"
        width="600"
        height="750"
        loading="eager"
      />
    </div>
  </section>

  <!-- Explanation: Reflex Zones -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-10">
        <span class="material-symbols-outlined text-[12rem]">footprint</span>
      </div>
      <div class="relative z-10 max-w-3xl">
        <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-[Inter] tracking-widest uppercase mb-6">Les Zones Réflexes</span>
        <h2 class="serif-display text-5xl md:text-6xl mb-10 leading-tight">
          Vos pieds, miroir de votre corps
        </h2>
        <div class="space-y-6 text-lg text-on-surface-variant leading-relaxed">
          <p>
            La réflexologie plantaire repose sur le principe que chaque <strong class="text-on-surface">zone du pied correspond à un organe ou une partie du corps</strong>. En stimulant ces zones réflexes par des pressions précises, on favorise le rétablissement de l'équilibre naturel de l'organisme.
          </p>
          <p>
            Cette pratique millénaire active les capacités d'auto-guérison du corps et rétablit la circulation énergétique. Une cartographie précise des pieds permet d'identifier les zones de tension et de travailler spécifiquement sur vos besoins.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Les Bienfaits</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((b) => (
        <div class="bg-surface-container-low p-8 rounded-[2rem] group hover:bg-surface-container-high transition-colors duration-500">
          <span class="material-symbols-outlined text-3xl text-primary mb-4 block">{b.icon}</span>
          <h3 class="serif-display text-xl mb-3">{b.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Session Process -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Déroulement d'une Séance</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      {[
        { icon: "chat", title: "1. Bilan Initial", desc: "Un échange pour comprendre vos besoins, vos antécédents et vos attentes. Ce bilan permet de personnaliser la séance." },
        { icon: "back_hand", title: "2. La Séance", desc: "Confortablement installé(e), vous recevez un soin sur les zones réflexes de vos pieds. La pression est adaptée à votre sensibilité." },
        { icon: "psychology", title: "3. Bilan & Conseils", desc: "Un temps de partage sur les zones sensibles identifiées et des conseils personnalisés pour prolonger les bienfaits." },
      ].map((step) => (
        <div class="space-y-6 text-center group">
          <div class="w-24 h-24 rounded-full bg-surface-container-high mx-auto flex items-center justify-center group-hover:bg-primary/5 transition-colors duration-500">
            <span class="material-symbols-outlined text-4xl text-primary">{step.icon}</span>
          </div>
          <h3 class="serif-display text-3xl">{step.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container-low rounded-[3rem] p-12 md:p-20 text-center">
      <h2 class="serif-display text-5xl mb-6">Investissement</h2>
      <p class="text-on-surface-variant text-lg mb-10 max-w-xl mx-auto">Une séance individuelle d'environ une heure pour un rééquilibrage complet.</p>
      <div class="inline-flex flex-col items-center bg-surface-container-lowest rounded-[2rem] p-12 shadow-sm">
        <span class="text-xs uppercase tracking-widest text-secondary mb-2 font-[Inter]">Séance individuelle</span>
        <span class="serif-display text-7xl text-primary mb-6">65€</span>
        <a href="/contact/" class="px-10 py-4 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-xs hover:opacity-90 transition-all">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 md:px-12 mb-32">
    <h2 class="serif-display text-5xl mb-16 text-center italic">Questions Fréquentes</h2>
    <FAQAccordion faqs={service.faqs} />
  </section>

  <!-- CTA -->
  <section class="mx-6 md:mx-12 mb-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    </div>
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Offrez du bien-être à vos pieds</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        Vos pieds portent le poids de votre quotidien. Offrez-leur une parenthèse de soin et d'attention.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Réserver votre séance
      </a>
    </div>
  </section>

  <!-- Related Services -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-20">
    <h2 class="serif-display text-4xl mb-12 text-center italic">Explorer d'autres soins</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/soins-energetiques/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">energy_savings_leaf</span>
        <h3 class="serif-display text-2xl mb-4">Soins Énergétiques</h3>
        <p class="text-on-surface-variant text-sm mb-6">Libérez vos blocages émotionnels et retrouvez votre vitalité.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-respiration-coherence-cardiaque/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">air</span>
        <h3 class="serif-display text-2xl mb-4">Respiration & Cohérence</h3>
        <p class="text-on-surface-variant text-sm mb-6">Régulez votre stress grâce à la cohérence cardiaque.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-thematiques/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">spa</span>
        <h3 class="serif-display text-2xl mb-4">Ateliers Thématiques</h3>
        <p class="text-on-surface-variant text-sm mb-6">Des moments de partage trimestriels autour du bien-être.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
    </div>
  </section>

</BaseLayout>
