---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('reflexologie-plantaire')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": {
        "@type": "Offer",
        "name": "Seance individuelle",
        "price": "65",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": service.shortName }
      ]
    }
  ]
};

const benefits = [
  { title: "Reduction du Stress", desc: "La stimulation des zones reflexes active le systeme parasympathique et apporte une relaxation profonde." },
  { title: "Meilleur Sommeil", desc: "En retablissant l'equilibre nerveux, la reflexologie favorise un endormissement plus rapide et un sommeil reparateur." },
  { title: "Digestion Amelioree", desc: "Les zones reflexes liees au systeme digestif aident a reguler les troubles fonctionnels." },
  { title: "Regain d'Energie", desc: "En liberant les blocages, l'energie circule a nouveau librement dans tout le corps." },
  { title: "Soulagement des Douleurs", desc: "Les tensions musculaires et certaines douleurs chroniques peuvent etre soulagees par la reflexologie." },
  { title: "Equilibre Emotionnel", desc: "Le pied est un miroir du corps : en travaillant les zones reflexes, on harmonise aussi les emotions." },
];
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">{service.shortName}</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-7 reveal">
          <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light">
            {service.heroHeading}
          </h1>
          <p class="text-charcoal/60 text-lg leading-relaxed max-w-xl font-light mb-8">
            {service.heroSubtitle}
          </p>
          <a href="/contact/" class="text-terracotta hover:text-terracotta/70 transition-colors duration-300 link-underline text-base">
            Prendre rendez-vous &rarr;
          </a>
        </div>
        <div class="lg:col-span-5 reveal">
          <img
            alt="Seance de reflexologie plantaire"
            class="w-full aspect-[3/4] object-cover rounded-2xl img-editorial"
            src="https://images.unsplash.com/photo-1519824145371-296894a0daa9?w=1200&q=80"
            width="600"
            height="800"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- What it is -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="max-w-3xl reveal">
          <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-6">Les zones reflexes</span>
          <h2 class="font-editorial text-3xl lg:text-4xl mb-8 font-light">Vos pieds, miroir de votre corps</h2>
          <div class="space-y-6 text-charcoal/60 font-light text-lg leading-relaxed">
            <p>
              La reflexologie plantaire repose sur le principe que chaque zone du pied correspond a un organe ou une partie du corps. En stimulant ces zones reflexes par des pressions precises, on favorise le retablissement de l'equilibre naturel de l'organisme.
            </p>
            <p>
              Cette pratique millenaire active les capacites d'auto-guerison du corps et retablit la circulation energetique. Une cartographie precise des pieds permet d'identifier les zones de tension et de travailler specifiquement sur vos besoins.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Les bienfaits</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-16 gap-y-12">
          {benefits.map((b) => (
            <div class="reveal">
              <h3 class="font-editorial text-xl mb-3">{b.title}</h3>
              <p class="text-charcoal/50 font-light text-sm leading-relaxed">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Session Process -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Deroulement d'une seance</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
          {[
            { num: "01", title: "Bilan Initial", desc: "Un echange pour comprendre vos besoins, vos antecedents et vos attentes. Ce bilan permet de personnaliser la seance." },
            { num: "02", title: "La Seance", desc: "Confortablement installe(e), vous recevez un soin sur les zones reflexes de vos pieds. La pression est adaptee a votre sensibilite." },
            { num: "03", title: "Bilan & Conseils", desc: "Un temps de partage sur les zones sensibles identifiees et des conseils personnalises pour prolonger les bienfaits." },
          ].map((step) => (
            <div class="reveal">
              <span class="text-terracotta/30 font-editorial text-4xl block mb-3">{step.num}</span>
              <h3 class="font-editorial text-xl mb-3">{step.title}</h3>
              <p class="text-charcoal/50 font-light leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-12 font-light reveal">Tarif</h2>
        <div class="border-t border-charcoal/5 reveal">
          <div class="flex justify-between items-baseline py-8">
            <span class="text-charcoal text-lg font-light">Seance individuelle</span>
            <span class="font-editorial text-3xl">65&euro;</span>
          </div>
        </div>
        <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Prendre rendez-vous &rarr;</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl lg:text-4xl mb-16 font-light reveal">Questions frequentes</h2>
        <div class="max-w-3xl reveal">
          <FAQAccordion faqs={service.faqs} />
        </div>
      </div>
    </section>

    <!-- Related -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <h2 class="font-editorial text-3xl mb-12 font-light reveal">Explorer d'autres soins</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
          <a class="group py-6 border-t border-charcoal/5" href="/soins-energetiques/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Soins Energetiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-respiration-coherence-cardiaque/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Respiration & Coherence</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
          <a class="group py-6 border-t border-charcoal/5" href="/ateliers-thematiques/">
            <h3 class="font-editorial text-xl mb-2 group-hover:text-terracotta transition-colors">Ateliers Thematiques</h3>
            <span class="text-terracotta text-sm">Decouvrir &rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <h2 class="font-editorial text-4xl lg:text-5xl mb-10 font-light">Offrez du bien-etre a vos pieds</h2>
        <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
          Reserver votre seance
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
