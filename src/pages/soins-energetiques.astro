---
import BaseLayout from '../components/BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getServiceBySlug } from '../data/services';
import { site } from '../data/site';

const service = getServiceBySlug('soins-energetiques')!;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": service.name,
      "description": service.description,
      "provider": {
        "@type": "HealthAndWellnessBusiness",
        "name": site.name,
        "url": site.url
      },
      "areaServed": { "@type": "City", "name": "Mortagne-au-Perche" },
      "offers": {
        "@type": "Offer",
        "name": "Séance individuelle",
        "price": "65",
        "priceCurrency": "EUR"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": service.faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer
        }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Soins", "item": `${site.url}/soins-energetiques/` },
        { "@type": "ListItem", "position": 3, "name": service.shortName }
      ]
    }
  ]
};
---

<BaseLayout
  title={service.metaTitle}
  description={service.metaDescription}
  schema={schema}
>

  <!-- Breadcrumb -->
  <nav class="pt-32 max-w-screen-xl mx-auto px-6 md:px-12">
    <ol class="flex gap-4 items-center text-sm font-[Inter] tracking-widest uppercase text-on-surface-variant/60">
      <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><a class="hover:text-primary transition-colors" href="/soins-energetiques/">Soins</a></li>
      <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
      <li><span class="text-primary/80">{service.shortName}</span></li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center py-20">
    <div class="space-y-8">
      <h1 class="serif-display text-6xl md:text-8xl leading-tight text-primary font-light">{service.heroHeading}</h1>
      <p class="text-xl md:text-2xl text-on-surface-variant font-light leading-relaxed max-w-xl">
        {service.heroSubtitle}
      </p>
      <div class="pt-4">
        <a href="/contact/" class="inline-block px-10 py-5 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:opacity-90 transition-all shadow-lg shadow-primary/10">
          Prendre rendez-vous
        </a>
      </div>
    </div>
    <div class="relative group">
      <div class="absolute inset-0 bg-secondary/5 rounded-[4rem] -rotate-3 scale-105 group-hover:rotate-0 transition-transform duration-700"></div>
      <img
        alt="Séance de soins énergétiques dans un cadre apaisant et lumineux"
        class="relative w-full aspect-[4/5] object-cover rounded-[3.5rem] shadow-2xl"
        src="/images/services/soins-energetiques.webp"
        width="600"
        height="750"
        loading="eager"
      />
    </div>
  </section>

  <!-- Educational: What is it? -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container rounded-[3rem] p-12 md:p-24 relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-10">
        <span class="material-symbols-outlined text-[12rem]">energy_savings_leaf</span>
      </div>
      <div class="relative z-10 max-w-3xl">
        <span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container text-xs font-[Inter] tracking-widest uppercase mb-6">Comprendre</span>
        <h2 class="serif-display text-5xl md:text-6xl mb-10 leading-tight">
          Qu'est-ce qu'un soin énergétique ?
        </h2>
        <div class="space-y-6 text-lg text-on-surface-variant leading-relaxed">
          <p>
            Un soin énergétique travaille sur la <strong class="text-on-surface">mémoire cellulaire du corps</strong> pour l'aider à libérer des blocages énergétiques et émotionnels. C'est une approche douce et non invasive qui considère le lien profond entre le corps, les émotions et la posture.
          </p>
          <p>
            Nos émotions non exprimées, nos traumatismes passés et nos tensions chroniques laissent une empreinte dans nos cellules. Le soin énergétique vise à rétablir la circulation naturelle de l'énergie dans le corps pour libérer ces mémoires et retrouver un état d'équilibre.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Link: Posture, Emotions, Chronic Pain -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Le Lien Corps — Émotions — Douleurs</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {[
        { icon: "accessibility_new", title: "La Posture", desc: "Votre posture reflète votre histoire émotionnelle. Des épaules voûtées, un dos bloqué : le corps parle de ce que les mots ne disent pas." },
        { icon: "favorite", title: "Les Émotions", desc: "Les émotions non exprimées s'inscrivent dans le corps sous forme de tensions, de contractures et de douleurs chroniques qui résistent aux traitements classiques." },
        { icon: "healing", title: "Les Douleurs Chroniques", desc: "Quand une douleur persiste malgré les soins, il est temps d'écouter ce que le corps essaie de nous dire à travers cette souffrance." },
      ].map((item) => (
        <div class="bg-surface-container-low p-10 rounded-[2.5rem] group hover:bg-surface-container-high transition-colors duration-500">
          <span class="material-symbols-outlined text-4xl text-primary mb-6 block">{item.icon}</span>
          <h3 class="serif-display text-2xl mb-4">{item.title}</h3>
          <p class="text-on-surface-variant leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How a Session Works -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="text-center mb-20">
      <h2 class="serif-display text-5xl mb-4">Déroulement d'une Séance</h2>
      <div class="h-1 w-20 bg-primary/20 mx-auto"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {[
        { step: "01", title: "Accueil & Échange", desc: "Un temps d'écoute pour comprendre vos besoins, votre histoire et vos attentes.", icon: "chat" },
        { step: "02", title: "Installation", desc: "Vous vous allongez confortablement. Le cadre est pensé pour favoriser la détente totale.", icon: "bed" },
        { step: "03", title: "Le Soin", desc: "Par contact léger ou à distance du corps, le soin libère les blocages énergétiques en douceur.", icon: "healing" },
        { step: "04", title: "Bilan & Ressentis", desc: "Un échange pour partager vos ressentis et comprendre les messages de votre corps.", icon: "psychology" },
      ].map((item) => (
        <div class="text-center group">
          <div class="w-20 h-20 rounded-full bg-surface-container-high mx-auto flex items-center justify-center group-hover:bg-primary/5 transition-colors duration-500 mb-6">
            <span class="material-symbols-outlined text-3xl text-primary">{item.icon}</span>
          </div>
          <span class="text-xs font-[Inter] uppercase tracking-widest text-secondary mb-2 block">{item.step}</span>
          <h3 class="serif-display text-xl mb-3">{item.title}</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-32">
    <div class="bg-surface-container-low rounded-[3rem] p-12 md:p-20 text-center">
      <h2 class="serif-display text-5xl mb-6">Investissement</h2>
      <p class="text-on-surface-variant text-lg mb-10 max-w-xl mx-auto">Une séance individuelle d'environ une heure, dans un cadre intime et bienveillant.</p>
      <div class="inline-flex flex-col items-center bg-surface-container-lowest rounded-[2rem] p-12 shadow-sm">
        <span class="text-xs uppercase tracking-widest text-secondary mb-2 font-[Inter]">Séance individuelle</span>
        <span class="serif-display text-7xl text-primary mb-6">65€</span>
        <a href="/contact/" class="px-10 py-4 bg-primary text-on-primary rounded-full font-[Inter] tracking-widest uppercase text-xs hover:opacity-90 transition-all">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-6 md:px-12 mb-32">
    <h2 class="serif-display text-5xl mb-16 text-center italic">Questions Fréquentes</h2>
    <FAQAccordion faqs={service.faqs} />
  </section>

  <!-- CTA -->
  <section class="mx-6 md:mx-12 mb-24 bg-primary-container text-on-primary-container rounded-[4rem] p-12 md:p-32 overflow-hidden relative text-center">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
    </div>
    <div class="relative z-10">
      <h2 class="serif-display text-5xl md:text-7xl mb-10 italic">Prêt(e) à libérer vos tensions ?</h2>
      <p class="text-xl opacity-80 mb-12 max-w-xl mx-auto font-[Newsreader] italic">
        Offrez à votre corps l'écoute qu'il mérite et retrouvez votre vitalité naturelle.
      </p>
      <a href="/contact/" class="inline-block px-12 py-6 bg-surface text-primary rounded-full font-[Inter] tracking-widest uppercase text-sm hover:bg-surface-container-lowest transition-colors shadow-2xl">
        Réserver votre séance
      </a>
    </div>
  </section>

  <!-- Related Services -->
  <section class="max-w-screen-xl mx-auto px-6 md:px-12 mb-20">
    <h2 class="serif-display text-4xl mb-12 text-center italic">Explorer d'autres soins</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/reflexologie-plantaire/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">footprint</span>
        <h3 class="serif-display text-2xl mb-4">Réflexologie Plantaire</h3>
        <p class="text-on-surface-variant text-sm mb-6">Harmonisez votre organisme par les zones réflexes du pied.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/ateliers-respiration-coherence-cardiaque/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">air</span>
        <h3 class="serif-display text-2xl mb-4">Respiration & Cohérence</h3>
        <p class="text-on-surface-variant text-sm mb-6">Régulez votre stress grâce à la cohérence cardiaque.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
      <a class="group block p-10 bg-surface-container hover:bg-primary/5 transition-all duration-500 rounded-[2rem]" href="/accompagnement-personnel/">
        <span class="material-symbols-outlined text-primary mb-6 block text-3xl">verified</span>
        <h3 class="serif-display text-2xl mb-4">Accompagnement Personnel</h3>
        <p class="text-on-surface-variant text-sm mb-6">Un parcours sur-mesure combinant toutes nos approches.</p>
        <span class="text-xs font-[Inter] uppercase tracking-[0.2em] text-primary group-hover:translate-x-2 inline-block transition-transform">Découvrir →</span>
      </a>
    </div>
  </section>

</BaseLayout>
