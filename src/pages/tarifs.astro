---
import BaseLayout from '../components/BaseLayout.astro';
import { services } from '../data/services';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Tarifs" }
      ]
    },
    ...services.map(s => ({
      "@type": "Service",
      "name": s.name,
      "provider": { "@type": "HealthAndWellnessBusiness", "name": site.name },
      "offers": s.pricing.map(p => ({
        "@type": "Offer",
        "name": p.label,
        "price": p.price === "Sur devis" ? undefined : p.price.replace('€', ''),
        "priceCurrency": p.price === "Sur devis" ? undefined : "EUR"
      }))
    }))
  ]
};
---

<BaseLayout
  title="Tarifs des Ateliers & Soins | Au Pour Quoi Pas"
  description="Découvrez nos tarifs : ateliers respiration dès 30€, ateliers thématiques 55€, soins énergétiques 65€, réflexologie 65€. Mortagne-au-Perche."
  schema={schema}
>

  <!-- Decorative Background -->
  <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
    <div class="absolute -top-[10%] -left-[5%] w-[40%] h-[40%] bg-secondary-container/20 organic-blob animate-breathe opacity-40"></div>
    <div class="absolute top-[40%] -right-[10%] w-[50%] h-[50%] bg-primary-fixed/10 organic-blob animate-float opacity-30" style="animation-delay: -2s;"></div>
    <div class="absolute -bottom-[10%] left-[20%] w-[30%] h-[30%] bg-surface-container-highest/40 organic-blob animate-float opacity-50" style="animation-delay: -5s;"></div>
  </div>

  <div class="relative z-10 pt-48 pb-40">

    <!-- Breadcrumb -->
    <nav class="max-w-screen-xl mx-auto px-8 mb-12">
      <ol class="flex gap-4 items-center text-[10px] font-[Inter] tracking-[0.3em] uppercase text-on-surface-variant/40">
        <li><a class="hover:text-primary transition-colors" href="/">Accueil</a></li>
        <li><span class="material-symbols-outlined text-[10px]">chevron_right</span></li>
        <li><span class="text-primary/70">Tarifs</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="max-w-screen-xl mx-auto px-8 mb-40 text-center">
      <span class="text-secondary font-[Inter] text-xs tracking-[0.4em] uppercase mb-8 block opacity-80">L'art de l'investissement intérieur</span>
      <h1 class="serif-display italic text-7xl md:text-9xl text-primary leading-[0.9] mb-12 tracking-tight">
        Tarifs <span class="block mt-4">& Accompagnements</span>
      </h1>
      <div class="w-24 h-px bg-outline-variant/30 mx-auto mb-12"></div>
      <p class="max-w-xl mx-auto text-on-surface-variant/80 text-xl leading-relaxed font-light serif-display italic">
        Chaque séance est une invitation au ralentissement, un espace sacré conçu pour s'adapter à votre propre rythme.
      </p>
    </header>

    <!-- Asymmetrical Pricing Grid -->
    <section class="max-w-screen-2xl mx-auto px-8 md:px-16">
      <div class="grid grid-cols-12 gap-y-32 gap-x-8">

        <!-- Card 1: Ateliers Respiration (Left offset) -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-1 reveal reveal-up">
          <div class="glass-card rounded-3xl p-12 md:p-16 editorial-shadow transition-all duration-700 hover:-translate-y-2">
            <h3 class="serif-display text-4xl italic text-primary mb-8">Ateliers Respiration</h3>
            <p class="text-on-surface-variant font-light mb-16 leading-relaxed text-lg italic">Le souffle comme point d'ancrage. Cohérence cardiaque et respiration consciente guidée.</p>
            <div class="space-y-10 mb-20">
              <div class="flex justify-between items-end border-b border-outline-variant/20 pb-6 group">
                <span class="font-[Inter] text-xs tracking-[0.2em] uppercase text-secondary/70">Initiation Groupe</span>
                <span class="serif-display italic text-4xl text-primary/90 group-hover:scale-110 transition-transform duration-500">30€</span>
              </div>
              <div class="flex justify-between items-end border-b border-outline-variant/20 pb-6 group">
                <span class="font-[Inter] text-xs tracking-[0.2em] uppercase text-secondary/70">Individuel</span>
                <span class="serif-display italic text-4xl text-primary/90 group-hover:scale-110 transition-transform duration-500">70€</span>
              </div>
              <div class="flex justify-between items-end border-b border-outline-variant/20 pb-6 group">
                <span class="font-[Inter] text-xs tracking-[0.2em] uppercase text-secondary/70">Forfait 5 séances</span>
                <span class="serif-display italic text-4xl text-primary/90 group-hover:scale-110 transition-transform duration-500">80€</span>
              </div>
              <div class="flex justify-between items-end pb-2 group">
                <span class="font-[Inter] text-xs tracking-[0.2em] uppercase text-secondary font-semibold">Forfait 10 séances</span>
                <span class="serif-display italic text-5xl text-primary group-hover:scale-110 transition-transform duration-500">140€</span>
              </div>
            </div>
            <a href="/contact/" class="block w-full py-5 border border-primary/20 text-primary font-[Inter] text-xs tracking-[0.3em] uppercase rounded-full hover:bg-primary hover:text-on-primary transition-all duration-700 text-center">
              Réserver l'expérience
            </a>
          </div>
        </div>

        <!-- Card 2: Ateliers Thématiques (Right offset, up) -->
        <div class="col-span-12 lg:col-span-5 lg:col-start-8 lg:-mt-24 reveal reveal-up">
          <div class="glass-card rounded-3xl p-12 md:p-16 editorial-shadow transition-all duration-700 hover:-translate-y-2">
            <div class="mb-12 aspect-square w-full bg-surface-container-low/50 organic-blob flex items-center justify-center overflow-hidden">
              <div class="text-center">
                <span class="block font-[Inter] text-xs tracking-[0.3em] text-secondary/60 mb-6 uppercase">Session immersive 2h</span>
                <span class="serif-display italic text-9xl text-primary opacity-90">55€</span>
              </div>
            </div>
            <h3 class="serif-display text-4xl italic text-primary mb-6">Ateliers Thématiques</h3>
            <p class="text-on-surface-variant font-light mb-12 leading-relaxed text-lg italic">Des rendez-vous saisonniers pour approfondir l'harmonie entre le corps et l'esprit.</p>
            <a href="/contact/" class="block w-full py-5 bg-surface-container-high/60 text-primary font-[Inter] text-xs tracking-[0.3em] uppercase rounded-full hover:bg-primary hover:text-on-primary transition-all duration-700 text-center">
              Choisir une date
            </a>
          </div>
        </div>

        <!-- Cards 3 & 4: Soins & Réflexologie (Center) -->
        <div class="col-span-12 lg:col-span-10 lg:col-start-2 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">
          <!-- Soins Énergétiques -->
          <div class="group flex flex-col items-center text-center p-12 glass-card rounded-3xl editorial-shadow hover:-translate-y-2 transition-transform duration-700 reveal reveal-up">
            <span class="serif-display italic text-8xl text-primary/20 mb-4">65€</span>
            <h3 class="serif-display text-3xl italic text-primary mb-6">Soins Énergétiques</h3>
            <p class="text-on-surface-variant font-light mb-12 italic">Libération des tensions et restauration de la vitalité naturelle profonde.</p>
            <a href="/contact/" class="px-12 py-4 border border-outline-variant/30 text-secondary font-[Inter] text-[10px] tracking-[0.4em] uppercase rounded-full hover:border-primary hover:text-primary transition-all duration-500 text-center">
              Réserver
            </a>
          </div>
          <!-- Réflexologie -->
          <div class="group flex flex-col items-center text-center p-12 glass-card rounded-3xl editorial-shadow hover:-translate-y-2 transition-transform duration-700 reveal reveal-up">
            <span class="serif-display italic text-8xl text-primary/20 mb-4">65€</span>
            <h3 class="serif-display text-3xl italic text-primary mb-6">Réflexologie Plantaire</h3>
            <p class="text-on-surface-variant font-light mb-12 italic">Une approche holistique pour apaiser l'esprit par les points réflexes.</p>
            <a href="/contact/" class="px-12 py-4 border border-outline-variant/30 text-secondary font-[Inter] text-[10px] tracking-[0.4em] uppercase rounded-full hover:border-primary hover:text-primary transition-all duration-500 text-center">
              Réserver
            </a>
          </div>
        </div>

        <!-- Card 5: Accompagnement Personnel (Wide hero-style) -->
        <div class="col-span-12 mt-20 reveal reveal-up">
          <div class="relative overflow-hidden glass-card rounded-[3rem] p-12 md:p-24 editorial-shadow border border-primary/5">
            <div class="absolute top-0 right-0 w-1/2 h-full bg-secondary-container/10 -skew-x-12 translate-x-1/4 pointer-events-none"></div>
            <div class="relative z-10 flex flex-col lg:flex-row items-center gap-16 lg:gap-32">
              <div class="lg:w-3/5">
                <span class="text-secondary font-[Inter] text-xs tracking-[0.4em] uppercase mb-8 block">Sur-mesure</span>
                <h3 class="serif-display text-5xl md:text-7xl italic text-primary mb-10 leading-tight">Accompagnement Personnel</h3>
                <p class="text-on-surface-variant text-xl font-light italic leading-relaxed mb-12">Un parcours de transformation durable, fusionnant nos expertises pour répondre à vos objectifs de sérénité profonde.</p>
                <div class="flex items-center gap-6 text-secondary/60">
                  <span class="material-symbols-outlined text-3xl">verified</span>
                  <span class="text-xs font-[Inter] uppercase tracking-[0.3em]">Suivi personnalisé inclus</span>
                </div>
              </div>
              <div class="lg:w-2/5 w-full">
                <div class="p-12 bg-white/40 rounded-3xl text-center border border-white/60 backdrop-blur-sm">
                  <span class="block serif-display italic text-6xl text-primary mb-12">Sur devis</span>
                  <a href="/contact/" class="block w-full py-6 bg-primary text-on-primary font-[Inter] text-xs tracking-[0.4em] uppercase rounded-full shadow-lg shadow-primary/20 hover:shadow-xl hover:-translate-y-1 transition-all duration-500 text-center">
                    Demander un devis
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Essential Oil / Group Info Section -->
    <section class="max-w-screen-xl mx-auto px-8 mt-64">
      <div class="flex flex-col md:flex-row items-center gap-32">
        <div class="w-full md:w-1/2 relative reveal">
          <div class="absolute -inset-4 border border-primary/10 rounded-2xl rotate-3 pointer-events-none"></div>
          <div class="aspect-[4/5] overflow-hidden rounded-2xl editorial-shadow">
            <img class="w-full h-full object-cover scale-110 hover:scale-100 transition-transform duration-[2000ms]" alt="Huiles essentielles et ambiance sereine" src="/images/tarifs/essential-oil.webp" width="500" height="625" loading="lazy" />
          </div>
        </div>
        <div class="w-full md:w-1/2 reveal reveal-up">
          <h2 class="serif-display italic text-5xl md:text-6xl text-primary mb-12 leading-tight">L'Expérience en Groupe</h2>
          <div class="space-y-10 text-on-surface-variant text-xl font-light italic leading-relaxed">
            <p class="relative">
              <span class="absolute -left-8 top-0 text-primary/20 text-6xl serif-display">&ldquo;</span>
              Afin de préserver la qualité de l'écoute et l'intimité nécessaire à chaque pratique, nos ateliers collectifs sont limités à <strong class="text-on-surface">8 personnes maximum</strong>.
            </p>
            <p>Une attention portée à l'individu au sein du collectif, garantissant une immersion totale.</p>
            <div class="pt-12">
              <span class="text-[10px] font-[Inter] uppercase tracking-[0.5em] text-secondary/60 mb-6 block">Conversations & Réservations</span>
              <a class="group text-3xl serif-display italic text-primary inline-flex items-center gap-4 transition-all duration-500" href={`mailto:${site.email}`}>
                <span>{site.email}</span>
                <span class="material-symbols-outlined group-hover:translate-x-3 transition-transform duration-500">east</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

</BaseLayout>
