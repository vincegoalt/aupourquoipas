---
import BaseLayout from '../components/BaseLayout.astro';
import { services } from '../data/services';
import { site } from '../data/site';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": site.url },
        { "@type": "ListItem", "position": 2, "name": "Tarifs" }
      ]
    },
    ...services.map(s => ({
      "@type": "Service",
      "name": s.name,
      "provider": { "@type": "HealthAndWellnessBusiness", "name": site.name },
      "offers": s.pricing.map(p => ({
        "@type": "Offer",
        "name": p.label,
        "price": p.price === "Sur devis" ? undefined : p.price.replace('€', ''),
        "priceCurrency": p.price === "Sur devis" ? undefined : "EUR"
      }))
    }))
  ]
};
---

<BaseLayout
  title="Tarifs des Ateliers & Soins | Au Pour Quoi Pas"
  description="Decouvrez nos tarifs : ateliers respiration des 30€, ateliers thematiques 55€, soins energetiques 65€, reflexologie 65€. Mortagne-au-Perche."
  schema={schema}
>

  <div class="pt-32 lg:pt-40">

    <!-- Breadcrumb -->
    <nav class="max-w-[1200px] mx-auto px-6 lg:px-24 mb-12">
      <ol class="flex gap-3 items-center text-[10px] font-sans tracking-[0.2em] uppercase text-charcoal/30">
        <li><a class="hover:text-terracotta transition-colors" href="/">Accueil</a></li>
        <li>&mdash;</li>
        <li><span class="text-charcoal/50">Tarifs</span></li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="max-w-[1200px] mx-auto px-6 lg:px-24 pb-32 lg:pb-48 border-b border-charcoal/5">
      <h1 class="font-editorial text-[clamp(2.5rem,4vw,5rem)] text-charcoal leading-[1.1] mb-8 font-light reveal">
        Tarifs & Accompagnements
      </h1>
      <p class="max-w-xl text-charcoal/60 text-lg leading-relaxed font-light reveal">
        Chaque seance est une invitation au ralentissement, un espace concu pour s'adapter a votre propre rythme.
      </p>
    </header>

    <!-- Ateliers Respiration -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
          <div class="lg:col-span-5 reveal">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Cohérence cardiaque</span>
            <h2 class="font-editorial text-3xl lg:text-4xl mb-6 font-light">Ateliers Respiration</h2>
            <p class="text-charcoal/50 font-light leading-relaxed mb-8">Le souffle comme point d'ancrage. Coherence cardiaque et respiration consciente guidee en petit groupe.</p>
            <img
              alt="Seance de respiration"
              class="w-full aspect-[16/9] object-cover rounded-lg img-editorial"
              src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&q=80"
              width="800"
              height="450"
              loading="lazy"
            />
          </div>
          <div class="lg:col-span-7 reveal">
            <div class="divide-y divide-charcoal/5">
              <div class="flex justify-between items-baseline py-8">
                <div>
                  <span class="text-charcoal text-lg font-light block">Initiation groupe</span>
                  <span class="text-charcoal/40 text-sm">1h15</span>
                </div>
                <span class="font-editorial text-3xl">30&euro;</span>
              </div>
              <div class="flex justify-between items-baseline py-8">
                <div>
                  <span class="text-charcoal text-lg font-light block">Initiation individuel</span>
                  <span class="text-charcoal/40 text-sm">1h15</span>
                </div>
                <span class="font-editorial text-3xl">70&euro;</span>
              </div>
              <div class="flex justify-between items-baseline py-8">
                <span class="text-charcoal text-lg font-light">Forfait 5 seances</span>
                <span class="font-editorial text-3xl">80&euro;</span>
              </div>
              <div class="flex justify-between items-baseline py-8">
                <span class="text-charcoal text-lg font-light">Forfait 10 seances</span>
                <span class="font-editorial text-3xl">140&euro;</span>
              </div>
            </div>
            <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Reserver &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Ateliers Thematiques -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
          <div class="lg:col-span-5 reveal">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Trimestriel</span>
            <h2 class="font-editorial text-3xl lg:text-4xl mb-6 font-light">Ateliers Thematiques</h2>
            <p class="text-charcoal/50 font-light leading-relaxed">Des rendez-vous saisonniers pour approfondir l'harmonie entre le corps et l'esprit. 2 heures en petit groupe.</p>
          </div>
          <div class="lg:col-span-7 reveal">
            <div class="divide-y divide-charcoal/5">
              <div class="flex justify-between items-baseline py-8">
                <div>
                  <span class="text-charcoal text-lg font-light block">Atelier thematique</span>
                  <span class="text-charcoal/40 text-sm">2h &middot; 6-8 personnes</span>
                </div>
                <span class="font-editorial text-3xl">55&euro;</span>
              </div>
            </div>
            <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Reserver &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Soins Energetiques & Reflexologie -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-20">
          <div class="reveal">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Individuel</span>
            <h2 class="font-editorial text-3xl lg:text-4xl mb-6 font-light">Soins Energetiques</h2>
            <p class="text-charcoal/50 font-light leading-relaxed mb-8">Liberation des tensions et restauration de la vitalite naturelle profonde.</p>
            <div class="border-t border-charcoal/5 pt-8">
              <div class="flex justify-between items-baseline">
                <span class="text-charcoal text-lg font-light">Seance individuelle</span>
                <span class="font-editorial text-3xl">65&euro;</span>
              </div>
            </div>
            <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Reserver &rarr;</a>
          </div>
          <div class="reveal">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Individuel</span>
            <h2 class="font-editorial text-3xl lg:text-4xl mb-6 font-light">Reflexologie Plantaire</h2>
            <p class="text-charcoal/50 font-light leading-relaxed mb-8">Une approche holistique pour apaiser l'esprit par les zones reflexes du pied.</p>
            <div class="border-t border-charcoal/5 pt-8">
              <div class="flex justify-between items-baseline">
                <span class="text-charcoal text-lg font-light">Seance individuelle</span>
                <span class="font-editorial text-3xl">65&euro;</span>
              </div>
            </div>
            <a href="/contact/" class="mt-6 inline-block text-terracotta hover:text-terracotta/70 transition-colors link-underline">Reserver &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Accompagnement Personnel -->
    <section class="py-32 lg:py-48 bg-warm-gray">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start reveal">
          <div class="lg:col-span-7">
            <span class="text-sage text-[10px] tracking-[0.2em] uppercase block mb-4">Sur-mesure</span>
            <h2 class="font-editorial text-3xl lg:text-4xl mb-6 font-light">Accompagnement Personnel</h2>
            <p class="text-charcoal/50 font-light leading-relaxed">Un parcours de transformation durable, fusionnant nos expertises pour repondre a vos objectifs de serenite profonde. Le devis est etabli apres notre premier echange.</p>
          </div>
          <div class="lg:col-span-5">
            <div class="border border-charcoal/5 rounded-lg p-10 text-center">
              <span class="font-editorial text-4xl block mb-6">Sur devis</span>
              <a href="/contact/" class="inline-block px-10 py-4 border border-terracotta text-terracotta rounded-full font-sans text-[11px] tracking-[0.2em] uppercase hover:bg-terracotta hover:text-white transition-all duration-300">
                Demander un devis
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="py-32 lg:py-48 bg-warm-white">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-24 text-center reveal">
        <p class="text-charcoal/50 font-light text-lg mb-4">Groupes limites a 8 personnes maximum</p>
        <p class="text-charcoal/50 font-light text-lg mb-10">
          Reservations : <a href={`mailto:${site.email}`} class="text-terracotta hover:text-terracotta/70 transition-colors link-underline">{site.email}</a>
        </p>
      </div>
    </section>

  </div>

</BaseLayout>
